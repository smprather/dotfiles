# Configuration must come first
# Since getting PATH setup is critical to the rest of the startup process, do
# PATH customization in these config files.
source_if_exists $BASH_CONFIG_ROOT_DIR/global/config.sh
source_if_exists $BASH_CONFIG_ROOT_DIR/corp/config.sh
source_if_exists $BASH_CONFIG_ROOT_DIR/site/config.sh
source_if_exists $BASH_CONFIG_ROOT_DIR/project/config.sh
source_if_exists $BASH_CONFIG_ROOT_DIR/user/config.sh

# Optionally exec into a preferred bash binary (e.g. newer bash from EE Linux Tools).
# Set cfg_preferred_bash=/full/path/to/bash in user/config.sh to enable.
# Silently skipped if the binary doesn't exist or isn't executable.
if [[ -n "${cfg_preferred_bash:-}" && -x "$cfg_preferred_bash" ]]; then
    _preferred_real=$(realpath "$cfg_preferred_bash" 2>/dev/null)
    _current_real=$(realpath /proc/$$/exe 2>/dev/null || realpath "$BASH" 2>/dev/null)
    if [[ -n "$_preferred_real" && "$_current_real" != "$_preferred_real" ]]; then
        exec "$cfg_preferred_bash"
    fi
fi

# PATH to common linux tools should be established by now
# More PATH can be added by Environment Modules in corp/site/project/user layers.
source_if_exists $BASH_CONFIG_ROOT_DIR/global/bashrc
source_if_exists $BASH_CONFIG_ROOT_DIR/corp/bashrc
source_if_exists $BASH_CONFIG_ROOT_DIR/site/bashrc
source_if_exists $BASH_CONFIG_ROOT_DIR/project/bashrc
source_if_exists $BASH_CONFIG_ROOT_DIR/user/bashrc

unset_bashrc_local_vars

# Clean up any PATH dupe dirs that may have crept in
path_trim PATH

