# ── helpers ────────────────────────────────────────────────────────────────

def _sha256_bytes(data):
    return hashlib.sha256(data).hexdigest()

def _sha256_file(path):
    h = hashlib.sha256()
    with open(path, "rb") as f:
        for chunk in iter(lambda: f.read(65536), b""):
            h.update(chunk)
    return h.hexdigest()

def _download(url, dest, verbose):
    if verbose:
        print("    GET {}".format(url), flush=True)
    req = Request(url, headers={"User-Agent": "dotfiles-verify-binaries/1.0"})
    with urlopen(req, timeout=120) as resp:
        with open(dest, "wb") as f:
            while True:
                chunk = resp.read(65536)
                if not chunk:
                    break
                f.write(chunk)

def _extract(archive, want, destdir, verbose):
    """Extract binary named `want` (matched by basename) from archive into destdir."""
    dest = os.path.join(destdir, want)
    if verbose:
        print("    extract '{}' from {}".format(want, os.path.basename(archive)), flush=True)

    # Try tar first (handles .tar.gz .tar.bz2 .tbz .tar.xz .tgz by magic)
    if tarfile.is_tarfile(archive):
        with tarfile.open(archive, "r:*") as tf:
            hit = None
            for m in tf.getmembers():
                if os.path.basename(m.name) == want and m.isfile():
                    hit = m
                    break
            if hit is None:
                names = [m.name for m in tf.getmembers()]
                raise ValueError("'{}' not found in archive. Contents: {}".format(
                    want, names[:8]))
            hit.name = want  # flatten to dest/want
            tf.extract(hit, destdir)
    elif zipfile.is_zipfile(archive):
        with zipfile.ZipFile(archive) as zf:
            hit = next((n for n in zf.namelist() if os.path.basename(n) == want), None)
            if hit is None:
                raise ValueError("'{}' not found in zip. Contents: {}".format(
                    want, zf.namelist()[:8]))
            data = zf.read(hit)
            with open(dest, "wb") as f:
                f.write(data)
    else:
        # Bare gzip or bare binary
        with open(archive, "rb") as f:
            magic = f.read(2)
        if magic == b"\x1f\x8b":
            with gzip.open(archive, "rb") as gz:
                with open(dest, "wb") as f:
                    shutil.copyfileobj(gz, f)
        else:
            shutil.copy2(archive, dest)

    os.chmod(dest, stat.S_IRWXU | stat.S_IRGRP | stat.S_IXGRP | stat.S_IROTH | stat.S_IXOTH)
    return dest

def _is_dynamic_elf(path):
    """True if the file is a dynamically linked ELF (needs RPATH set)."""
    try:
        r = subprocess.run(["file", "-b", path], capture_output=True, text=True)
        return "dynamically linked" in r.stdout
    except Exception:
        return False

def _strip(path, verbose):
    if verbose:
        print("    strip {}".format(os.path.basename(path)), flush=True)
    r = subprocess.run([_STRIP, path], capture_output=True)
    # strip exits non-zero on already-stripped or non-ELF files — that's fine
    return r.returncode

def _patchelf_rpath(path, verbose):
    """Apply standard bin/ RPATH — matches our pre-commit bundling step."""
    if not _PATCHELF or not os.path.exists(_PATCHELF):
        return False
    if verbose:
        print("    patchelf --set-rpath '{}' {}".format(_BIN_RPATH, os.path.basename(path)), flush=True)
    r = subprocess.run([_PATCHELF, "--set-rpath", _BIN_RPATH, path], capture_output=True)
    return r.returncode == 0

def _needed_libs(path):
    """Return sorted list of NEEDED shared libraries from ELF .dynamic section."""
    try:
        r = subprocess.run(["readelf", "-d", path], capture_output=True, text=True)
        return sorted(m.group(1) for m in re.finditer(r'\(NEEDED\)\s+.*\[(.+?)\]', r.stdout))
    except Exception:
        return []

def _bundled_bytes(stem):
    """Decompress bundled .bz2 and return raw bytes, or None if not found."""
    bz2_path = os.path.join(_BIN_DIR, stem + ".bz2")
    if not os.path.exists(bz2_path):
        return None
    with bz2.open(bz2_path, "rb") as f:
        return f.read()

def _load_tools_json():
    with open(_TOOLS_JSON) as f:
        data = json.load(f)
    # Strip comment keys
    return {k: v for k, v in data.items() if not k.startswith("_")}

# ── verification ───────────────────────────────────────────────────────────

def _verify_one(name, entry, version, tmpdir, verbose):
    """Returns (status, detail) where status is 'PASS'/'FAIL'/'ERROR'."""
    url = entry["url"].format(ver=version)
    want = entry["bin"]

    # Download
    archive = os.path.join(tmpdir, name + "_archive")
    try:
        _download(url, archive, verbose)
    except HTTPError as e:
        return "ERROR", "HTTP {} from {}".format(e.code, url)
    except URLError as e:
        return "ERROR", "download failed: {}".format(e.reason)
    except Exception as e:
        return "ERROR", "download: {}".format(e)

    # Extract
    extracted = os.path.join(tmpdir, name + "_bin")
    try:
        _extract(archive, want, tmpdir, verbose)
        # _extract places result at tmpdir/want; rename to our expected path
        extracted_raw = os.path.join(tmpdir, want)
        if os.path.exists(extracted_raw) and extracted_raw != extracted:
            os.rename(extracted_raw, extracted)
        elif not os.path.exists(extracted):
            extracted = extracted_raw
    except Exception as e:
        return "ERROR", "extract: {}".format(e)

    # Reproduce our bundling transformation: strip → patchelf (for dynamic ELFs)
    # Order matters: strip must come before patchelf or .dynstr gets corrupted.
    _strip(extracted, verbose)
    if _is_dynamic_elf(extracted):
        _patchelf_rpath(extracted, verbose)

    # Compare
    upstream_hash = _sha256_file(extracted)
    bundled_data = _bundled_bytes(want)
    if bundled_data is None:
        # Try the tool name as stem too (e.g. miller→mlr)
        bundled_data = _bundled_bytes(name)
    if bundled_data is None:
        return "ERROR", "bundled .bz2 not found for '{}' or '{}'".format(want, name)

    bundled_hash = _sha256_bytes(bundled_data)

    if upstream_hash == bundled_hash:
        return "PASS", upstream_hash[:16] + "..."

    # Full hash mismatch. For dynamic ELFs, check if only patchelf section layout differs
    # (patchelf rewrites .dynamic, shifting offsets slightly even when setting same RPATH).
    # Compare NEEDED libraries as a proxy for "same binary, different patchelf stamp".
    if _is_dynamic_elf(extracted):
        bundled_tmp = os.path.join(os.path.dirname(extracted), name + "_bundled_tmp")
        with open(bundled_tmp, "wb") as f:
            f.write(bundled_data)
        up_needed  = _needed_libs(extracted)
        bnd_needed = _needed_libs(bundled_tmp)
        up_sz  = os.path.getsize(extracted)
        bnd_sz = len(bundled_data)
        # Allow up to 0.5% size drift — patchelf restructures the ELF when adding/replacing
        # RPATH entries, which can shift section boundaries for large binaries.
        size_tolerance = max(8192, int(max(up_sz, bnd_sz) * 0.005))
        if up_needed == bnd_needed and abs(up_sz - bnd_sz) < size_tolerance:
            return "PASS", "patchelf layout delta only (code+deps identical)"
        else:
            return "FAIL", "different deps/size: up={} bnd={}".format(
                ",".join(up_needed) or "none", ",".join(bnd_needed) or "none")

    return "FAIL", "upstream={} bundled={}".format(
        upstream_hash[:16] + "...", bundled_hash[:16] + "...")

# ── main ───────────────────────────────────────────────────────────────────

def main():
    p = argparse.ArgumentParser(
        description="Verify bundled .bz2 binaries against upstream releases.")
    p.add_argument("tools", nargs="*", metavar="TOOL",
                   help="Tool(s) to verify. Default: all registered.")
    p.add_argument("--keep", action="store_true",
                   help="Keep temp directory after exit.")
    p.add_argument("-v", "--verbose", action="store_true",
                   help="Show download/extract/strip steps.")
    args = p.parse_args()

    registry  = _load_tools_json()
    sel_tools = args.tools if args.tools else sorted(registry.keys())

    # Validate --tool names
    unknown = [t for t in sel_tools if t not in registry]
    if unknown:
        print("Unknown tool(s): {}".format(", ".join(unknown)), file=sys.stderr)
        print("Known: {}".format(", ".join(sorted(registry.keys()))), file=sys.stderr)
        sys.exit(1)

    tmpdir = tempfile.mkdtemp(prefix="dotfiles-verify.")
    if args.verbose:
        print("Temp dir: {}".format(tmpdir))

    # Column widths
    w_name   = max(len(t) for t in sel_tools)
    w_ver    = max((len(registry[t].get("version", "")) for t in sel_tools), default=7)
    w_status = 5

    hdr = "{:<{n}}  {:<{v}}  {:<{s}}  {}".format(
        "TOOL", "VERSION", "STATUS", "DETAIL",
        n=w_name, v=w_ver, s=w_status)
    sep = "{:<{n}}  {:<{v}}  {:<{s}}  {}".format(
        "-" * w_name, "-" * w_ver, "-" * w_status, "-" * 40,
        n=w_name, v=w_ver, s=w_status)
    print(hdr)
    print(sep)

    counts = {"PASS": 0, "FAIL": 0, "SKIP": 0, "ERROR": 0}
    fail_names = []

    for name in sel_tools:
        tool_info = registry[name]
        version   = tool_info.get("version", "")

        def _row(status, detail):
            return "{:<{n}}  {:<{v}}  {:<{s}}  {}".format(
                name, version, status, detail,
                n=w_name, v=w_ver, s=w_status)

        if name in _SKIP_REASONS:
            print(_row("SKIP", _SKIP_REASONS[name]))
            counts["SKIP"] += 1
            continue

        if name not in _REGISTRY:
            print(_row("SKIP", "not in verify-binaries registry"))
            counts["SKIP"] += 1
            continue

        entry = _REGISTRY[name]
        if not version:
            print(_row("SKIP", "no version in tools.json"))
            counts["SKIP"] += 1
            continue

        if args.verbose:
            print("  [{}] {}".format(name, entry["url"].format(ver=version)))

        status, detail = _verify_one(name, entry, version, tmpdir, args.verbose)
        print(_row(status, detail))
        counts[status] += 1
        if status == "FAIL":
            fail_names.append(name)

    print(sep)
    print("{} passed, {} failed, {} skipped, {} error(s)".format(
        counts["PASS"], counts["FAIL"], counts["SKIP"], counts["ERROR"]))

    if fail_names:
        print("\nFAIL: {}".format(", ".join(fail_names)))
        print("Possible causes: wrong URL variant (gnu vs musl), source build,")
        print("or the bundled binary does not match the upstream release.")

    if not args.keep:
        shutil.rmtree(tmpdir, ignore_errors=True)
    else:
        print("\nTemp dir kept: {}".format(tmpdir))

    sys.exit(0 if counts["FAIL"] == 0 and counts["ERROR"] == 0 else 1)

if __name__ == "__main__":
    main()
