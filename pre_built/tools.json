{
  "_comment": "Tool registry for the dotfiles installer. See pre_built/ADDING_BINARIES.md for the workflow.",
  "_schema": {
    "bins":        "List of bin/*.bz2 stems (without .bz2) owned by this tool.",
    "libs":        "List of lib64/*.bz2 stems exclusively owned by this tool. Omit or leave empty for libs shared by multiple tools — those are always installed. Exclusively-owned libs are skipped when the tool is not selected.",
    "typelibs":    "List of typelibs/*.typelib files required by this tool (documentation only; all typelibs in the dir are always installed).",
    "wheels":      "List of Python package names whose wheels are bundled in wheels/ for offline uv tool install.",
    "uv_tool":     "Package name passed to 'uv tool install' for Python-based tools. Triggers install_python_tools().",
    "version":     "Version of the bundled binary or package.",
    "description": "One-line description shown by --list-tools.",
    "optional":    "If true, not installed by default. User must opt in with --add-tools."
  },

  "agent-deck":  {"bins": ["agent-deck"],        "version": "1.9.12",     "description": "TUI dashboard for AI agent orchestration"},
  "bash":        {"bins": ["bash"],               "version": "5.3.9",      "description": "Portable GNU Bash ahead of EL8 system version"},
  "bat":         {"bins": ["bat"],                "version": "0.26.1",     "description": "cat clone with syntax highlighting and line numbers"},
  "broot":       {"bins": ["broot"],              "version": "1.56.2",     "description": "Interactive tree navigator with fuzzy search"},
  "btm":         {"bins": ["btm"],                "version": "0.12.3",     "description": "Cross-platform system resource monitor (TUI)"},
  "btop":        {"bins": ["btop"],               "version": "1.4.7",      "description": "Resource monitor with graphs and mouse support"},
  "bzip2":       {"bins": ["bzip2"],              "version": "1.0.8",      "description": "Block-sorting file compressor"},
  "choose":      {"bins": ["choose"],             "version": "1.3.7",      "description": "awk/cut alternative for column field selection"},
  "dasel":       {"bins": ["dasel"],              "version": "3.8.1",      "description": "Query and modify YAML/JSON/TOML/XML/CSV data"},
  "delta":       {"bins": ["delta"],              "version": "0.19.2",     "description": "Git diff pager with syntax highlighting"},
  "duf":         {"bins": ["duf"],                "version": "0.9.1",      "description": "df replacement with colored usage table"},
  "dust":        {"bins": ["dust"],               "version": "1.2.4",      "description": "du replacement with visual bar chart"},
  "eza":         {"bins": ["eza"],                "version": "0.23.4",     "description": "ls replacement with icons, colors, git status"},
  "fd":          {"bins": ["fd"],                 "version": "10.4.2",     "description": "Fast and user-friendly find alternative"},
  "fzf":         {"bins": ["fzf"],                "version": "0.62.0",     "description": "General-purpose command-line fuzzy finder"},
  "gnuplot":     {"bins": ["gnuplot"],            "version": "6.0.2",      "description": "Command-line graphing and plotting utility"},
  "gping":       {"bins": ["gping"],              "version": "1.20.1",     "description": "Ping with live graph visualization"},
  "htop":        {"bins": ["htop"],               "version": "3.2.1",      "description": "Interactive process viewer and manager"},
  "hx":          {"bins": ["hx"],                 "version": "25.07.1",    "description": "Modern modal text editor with tree-sitter and LSP"},
  "hyperfine":   {"bins": ["hyperfine"],          "version": "1.20.0",     "description": "Command-line benchmarking tool"},
  "jq":          {"bins": ["jq"],
                  "libs": ["libjq.so", "libjq.so.1", "libjq.so.1.0.4", "libonig.so.5"],
                  "version": "1.8.1",
                  "description": "Lightweight JSON processor and formatter"},
  "just":        {"bins": ["just"],               "version": "1.50.0",     "description": "Command runner, ergonomic Makefile alternative"},
  "kak":         {"bins": ["kak"],                "version": "2026.04.12", "description": "Modal editor with multiple simultaneous selections"},
  "lazygit":     {"bins": ["lazygit"],            "version": "0.61.1",     "description": "TUI git client for staging, committing, rebasing"},
  "micro":       {"bins": ["micro"],              "version": "2.0.16-dev", "description": "Beginner-friendly terminal text editor"},
  "miller":      {"bins": ["mlr"],                "version": "6.18.1",     "description": "CSV/TSV/JSON/NDJSON data processor (mlr)"},
  "nvim":        {"bins": ["nvim"],               "version": "0.13-dev",   "description": "Hyperextensible Vim-based text editor"},
  "patchelf":    {"bins": ["patchelf"],           "version": "0.12",       "description": "Modify ELF RPATH and interpreter in-place"},
  "pigz":        {"bins": ["pigz"],               "version": "2.8",        "description": "Parallel implementation of gzip"},
  "procs":       {"bins": ["procs"],              "version": "0.14.11",    "description": "ps replacement with colors and process tree"},
  "pv":          {"bins": ["pv"],                 "version": "1.6.6",      "description": "Monitor and show progress of data through a pipe"},
  "rg":          {"bins": ["rg"],                 "version": "15.1.0",     "description": "Extremely fast grep alternative (ripgrep)"},
  "rsync":       {"bins": ["rsync"],
                  "libs": ["libxxhash.so.0"],
                  "version": "3.4.1",
                  "description": "Efficient file sync with delta-transfer algorithm"},
  "ruff":        {"bins": ["ruff"],               "version": "0.15.12",    "description": "Extremely fast Python linter and formatter"},
  "sd":          {"bins": ["sd"],                 "version": "1.0.0",      "description": "sed alternative with simpler regex syntax"},
  "shfmt":       {"bins": ["shfmt"],              "version": "3.13.1",     "description": "Shell script formatter and parser"},
  "starship":    {"bins": ["starship"],           "version": "1.25.1",     "description": "Cross-shell customizable minimal prompt"},
  "stylua":      {"bins": ["stylua"],             "version": "2.4.1",      "description": "Opinionated Lua code formatter"},
  "tkdiff":      {"bins": ["tkdiff"],             "version": "6.0",        "description": "Tcl/Tk visual diff and merge tool (needs wish)"},
  "tldr":        {"bins": ["tldr"],               "version": "1.8.1",      "description": "Simplified community man pages (tealdeer)"},
  "tmux":        {"bins": ["tmux"],
                  "libs": ["libevent_core-2.1.so.6"],
                  "version": "3.6a",
                  "description": "Terminal multiplexer with session management"},
  "tree-sitter": {"bins": ["tree-sitter"],        "version": "0.26.8",     "description": "Incremental parser generator and query tool"},
  "ty":          {"bins": ["ty"],                 "version": "0.0.35",     "description": "Fast Python type checker (Astral)"},
  "uv":          {"bins": ["uv"],                 "version": "0.11.13",    "description": "Extremely fast Python package and project manager"},
  "vim":         {"bins": ["vim", "vim.bin"],     "version": "9.2",        "description": "Vi IMproved text editor"},
  "gvim":        {"bins": ["gvim", "gvim.bin"],   "version": "9.2",        "description": "GTK3 GUI Vim with clipboard and font rendering",  "optional": true},
  "nedit-ng":    {"bins": ["nedit-ng"],           "version": "dev",        "description": "Qt5 GUI text editor, NEdit rewrite",               "optional": true},

