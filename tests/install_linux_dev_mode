#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<EOF
Usage: $0 [OPTIONS]

Test the Linux installer --dev and --no-backup modes.

Options:
  --keep-home       Print and keep the temp HOME after the test.
  --help, -h        Show this help message.
EOF
}

keep_home=0

while [[ $# -gt 0 ]]; do
    case "$1" in
    --keep-home)
        keep_home=1
        shift
        ;;
    --help | -h)
        usage
        exit 0
        ;;
    *)
        echo "Unknown option: $1" >&2
        usage >&2
        exit 1
        ;;
    esac
done

script_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
repo_dir=$(cd "$script_dir/.." && pwd)
test_home=$(mktemp -d /tmp/dotfiles-install-home.XXXXXX)
test_cache=$(mktemp -d /tmp/dotfiles-install-cache.XXXXXX)
test_state=$(mktemp -d /tmp/dotfiles-install-state.XXXXXX)
test_hooks=$(mktemp -d /tmp/dotfiles-install-hooks.XXXXXX)

cleanup() {
    if [[ "$keep_home" == "1" ]]; then
        echo "Kept temp HOME: $test_home"
        echo "Kept XDG_CACHE_HOME: $test_cache"
        echo "Kept XDG_STATE_HOME: $test_state"
    else
        rm -rf "$test_home" "$test_cache" "$test_state" "$test_hooks"
    fi
}
trap cleanup EXIT

assert_exists() {
    local path="$1"
    if [[ ! -e "$path" && ! -L "$path" ]]; then
        echo "Missing expected path: $path" >&2
        exit 1
    fi
}

assert_symlink() {
    local path="$1"
    if [[ ! -L "$path" ]]; then
        echo "Expected symlink: $path" >&2
        exit 1
    fi
}

assert_symlink_target() {
    local path="$1" expected_target="$2"
    local actual_target
    actual_target=$(readlink "$path")
    if [[ "$actual_target" != "$expected_target" ]]; then
        echo "Expected $path -> $expected_target, got $actual_target" >&2
        exit 1
    fi
}

cat > "$test_hooks/hook.sh" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
{
    echo "mode=$DOTFILES_MODE"
    echo "backup=$DOTFILES_BACKUP_DIR"
    echo "no_backup=$DOTFILES_NO_BACKUP"
} >> "$DOTFILES_HOME/hook.log"
EOF
chmod +x "$test_hooks/hook.sh"

echo "=== Test 1: --dev --no-fonts (dev mode skips backups inherently) ==="
echo "Temp HOME: $test_home"
(
    cd /tmp
    HOME="$test_home" \
        XDG_CACHE_HOME="$test_cache" \
        XDG_STATE_HOME="$test_state" \
        "$repo_dir/install" --dev --no-fonts \
        --post-install-hook "$test_hooks/hook.sh"
)

# Dev mode: top-level dirs are symlinked to the repo
assert_symlink_target "$test_home/.config/nvim" "$repo_dir/nvim"
assert_symlink_target "$test_home/.config/vim" "$repo_dir/vim"
assert_symlink_target "$test_home/.config/tmux" "$repo_dir/tmux"
assert_symlink_target "$test_home/.config/starship" "$repo_dir/starship"
assert_symlink_target "$test_home/.config/editorconfig" "$repo_dir/editorconfig"

# Dev mode bash: individual file-level symlinks, not a directory symlink
assert_symlink_target "$test_home/.config/bash/global" "$repo_dir/bash/global"
assert_symlink_target "$test_home/.config/bash/bashrc" "$repo_dir/bash/bashrc"
assert_symlink_target "$test_home/.config/bash/functions.sh" "$repo_dir/bash/functions.sh"
# bash config dir itself is not a symlink to the repo
if [[ -L "$test_home/.config/bash" ]]; then
    echo "Expected ~/.config/bash to be a real dir in dev mode, not a symlink" >&2
    exit 1
fi

# Entrypoints are symlinks
assert_symlink "$test_home/.bashrc"
assert_symlink "$test_home/.bash_profile"
assert_symlink "$test_home/.bash_login"
assert_symlink "$test_home/.profile"
assert_symlink "$test_home/.vimrc"
assert_symlink "$test_home/.tmux.conf"
assert_symlink "$test_home/.editorconfig"

# Config-level content reachable through the links
assert_exists "$test_home/.config/nvim/init.lua"
assert_exists "$test_home/.config/bash/bashrc"

# No backup created in dev mode
if [[ -d "$test_home/dotfiles_backups" ]]; then
    echo "Expected no backup dir in dev mode" >&2
    exit 1
fi

# Hook env: mode=dev, backup_dir empty
assert_exists "$test_home/hook.log"
if ! grep -q "^mode=dev$" "$test_home/hook.log"; then
    echo "Expected DOTFILES_MODE=dev in hook env" >&2
    cat "$test_home/hook.log" >&2
    exit 1
fi
if ! grep -q "^backup=$" "$test_home/hook.log"; then
    echo "Expected empty DOTFILES_BACKUP_DIR in dev mode" >&2
    cat "$test_home/hook.log" >&2
    exit 1
fi
if ! grep -q "^no_backup=0$" "$test_home/hook.log"; then
    echo "Expected DOTFILES_NO_BACKUP=0 (dev skips backup inherently, not via --no-backup)" >&2
    cat "$test_home/hook.log" >&2
    exit 1
fi

echo ""
echo "=== Test 2: --no-backup --no-fonts reports empty DOTFILES_BACKUP_DIR ==="
test_home2=$(mktemp -d /tmp/dotfiles-install-home.XXXXXX)
test_cache2=$(mktemp -d /tmp/dotfiles-install-cache.XXXXXX)
test_state2=$(mktemp -d /tmp/dotfiles-install-state.XXXXXX)
cleanup2() { rm -rf "$test_home2" "$test_cache2" "$test_state2"; }
trap "cleanup; cleanup2" EXIT

cat > "$test_hooks/hook2.sh" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
{
    echo "backup=$DOTFILES_BACKUP_DIR"
    echo "no_backup=$DOTFILES_NO_BACKUP"
} >> "$DOTFILES_HOME/hook2.log"
EOF
chmod +x "$test_hooks/hook2.sh"

(
    cd /tmp
    HOME="$test_home2" \
        XDG_CACHE_HOME="$test_cache2" \
        XDG_STATE_HOME="$test_state2" \
        "$repo_dir/install" --no-backup --no-fonts \
        --post-install-hook "$test_hooks/hook2.sh"
)

assert_exists "$test_home2/hook2.log"
if ! grep -q "^backup=$" "$test_home2/hook2.log"; then
    echo "Expected empty DOTFILES_BACKUP_DIR when --no-backup is passed" >&2
    cat "$test_home2/hook2.log" >&2
    exit 1
fi
if ! grep -q "^no_backup=1$" "$test_home2/hook2.log"; then
    echo "Expected DOTFILES_NO_BACKUP=1 when --no-backup is passed" >&2
    cat "$test_home2/hook2.log" >&2
    exit 1
fi
if [[ -d "$test_home2/dotfiles_backups" ]]; then
    echo "Expected no backup dir when --no-backup is passed" >&2
    exit 1
fi

echo ""
echo "Install dev-mode and no-backup smoke OK"
