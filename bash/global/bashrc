cd() {
    if [[ "$1" == "cd" ]]; then
        shift
    fi

    local target="$1"
    local response=""
    local create_base=""

    if [[ -d "$1" ]]; then
        target=$1
    elif [[ -z "$1" ]]; then
        target=$HOME
    elif [[ "$1" == "-" ]]; then
        target="-"
    elif [[ -L "$1" || -e "$1" ]]; then
        target=$(dirname -- "$1")
    elif [[ -n "$target" ]]; then
        create_base=$target
        while [[ $create_base != "/" && $create_base != "." && ! -e "$create_base" ]]; do
            create_base=$(dirname -- "$create_base")
        done

        if [[ -d "$create_base" && -w "$create_base" ]]; then
            read -r -p "$target does not exist. Create it with parent directories? [y]/n " response
            if [[ -z "$response" || $response =~ ^[Yy]$ ]]; then
                mkdir -p -- "$target" || return
            else
                return
            fi
        fi
    fi

    builtin cd "$target" && human_readable=0 ls
    # z "$target" && human_readable=0 ls
}

extract_rpm() {
    rpm2cpio "$1" | cpio -idmv
}

zhead() {
    zcat "${@: -1}" | head $(array_slice 0:-1 ${@})
}

# Executing a directory will cd to that directory. Makes it so that you can
# paste a directory to the cmd line w/o a cd first.
trap 'last_cmd=$BASH_COMMAND; [[ -r $last_cmd && -d $last_cmd ]] && cd $last_cmd || ( [[ -r $last_cmd && ! -x $last_cmd ]] && cd $(/bin/dirname $last_cmd) )' ERR

