#!/bin/bash
if ! command -v rsync >/dev/null; then
    echo "Error: This script requires rsync."
    exit 1
fi

# --- Argument parsing ---

dev_mode=0
links_mode=0
no_backup=0
no_fonts=0
post_install_hook=""
restore_backup=""

while [[ $# -gt 0 ]]; do
    case "$1" in
    --dev)
        dev_mode=1
        shift
        ;;
    --links)
        links_mode=1
        shift
        ;;
    --no-backup)
        no_backup=1
        shift
        ;;
    --no-fonts)
        no_fonts=1
        shift
        ;;
    --post-install-hook)
        if [[ -z "$2" ]]; then
            echo "Error: --post-install-hook requires a script path"
            echo "Usage: $0 --post-install-hook <script>"
            echo "Example: $0 --post-install-hook ~/corp-dotfiles/install.sh"
            exit 1
        fi
        post_install_hook="$2"
        shift 2
        ;;
    --verbose)
        # Kept for backwards compatibility; output is always verbose
        shift
        ;;
    --restore-backup)
        if [[ -z "$2" ]]; then
            echo "Error: --restore-backup requires a backup directory path"
            echo "Usage: $0 --restore-backup <backup_dir>"
            echo "Example: $0 --restore-backup dotfiles_backups/backup.1"
            exit 1
        fi
        restore_backup="$2"
        shift 2
        ;;
    --help | -h)
        cat <<EOF
Usage: $0 [OPTIONS]

Install dotfiles to the home directory.

Options:
  (default)                  Copy files from repo — no symlinks to the repo remain.
                             Re-run ./install after repo changes to update.

  --links                    Symlink individual files/dirs to the repo instead of copying.
                             Changes in the repo take effect immediately.

  --dev                      Directory-level symlinks to the repo (e.g. ~/.config/nvim -> repo/nvim).
                             Easiest when editing files frequently. Skips backups.

  --no-backup                Skip creating a backup of existing dotfiles before installing.

  --no-fonts                 Skip installing vendored fonts to ~/.local/share/fonts.

  --post-install-hook <script>
                             Run a corp/site/user script after global install steps.
                             The script is run with bash and receives DOTFILES_* env vars.

  --restore-backup <dir>     Restore dotfiles from a previous backup directory.
                             Example: $0 --restore-backup dotfiles_backups/backup.1

  --help, -h                 Show this help message.
EOF
        exit 0
        ;;
    *)
        echo "Unknown option: $1"
        echo "Usage: $0 [--dev] [--links] [--no-backup] [--no-fonts] [--post-install-hook <script>] [--verbose] [--restore-backup <dir>]"
        echo "Run '$0 --help' for details."
        exit 1
        ;;
    esac
done

# --- Helper functions ---

lns() {
    local unsafe=false
    local verbose=false
    local args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
        --unsafe)
            unsafe=true
            shift
            ;;
        --verbose)
            verbose=true
            shift
            ;;
        *)
            args+=("$1")
            shift
            ;;
        esac
    done

    if [[ ${#args[@]} -lt 2 ]]; then
        echo "Error: lns requires at least 2 arguments (target and link_name)" >&2
        return 1
    fi

    local link_name="${args[@]: -1}"

    if [[ -e "$link_name" || -L "$link_name" ]]; then
        if [[ -d "$link_name" && ! -L "$link_name" ]]; then
            if [[ "$unsafe" == false ]]; then
                echo "Error: '$link_name' exists as a directory and cannot be removed (use --unsafe to override)" >&2
                exit 1
            else
                [[ "$verbose" == true ]] && echo "rm -rf '$link_name'" >&2
                if ! rm -rf "$link_name" 2>/dev/null; then
                    echo "Error: Failed to remove directory '$link_name'" >&2
                    exit 1
                fi
            fi
        else
            [[ "$verbose" == true ]] && echo "rm -f '$link_name'" >&2
            if ! rm -f "$link_name" 2>/dev/null; then
                echo "Error: Failed to remove '$link_name'" >&2
                exit 1
            fi
        fi
    fi

    [[ "$verbose" == true ]] && echo "ln -s ${args[*]}" >&2
    ln -s "${args[@]}"
}

mkdirn() {
    local base_dir="$1"
    local target_dir="$base_dir"
    local counter=1

    if [[ ! -e "$target_dir" ]]; then
        mkdir -p "$target_dir"
        echo "$target_dir"
        return 0
    fi

    while [[ -e "$target_dir" ]]; do
        target_dir="${base_dir}.${counter}"
        ((counter++))
    done

    mkdir -p "$target_dir"
    echo "$target_dir"
}

# Install a file or directory from the repo.
# --links mode: symlink to repo. Default: copy (no repo reference remains).
# Local convenience symlinks (.bashrc/.bash_profile/.bash_login/.profile -> .config/bash/bashrc) use lns directly.
inst() {
    local src="$1"
    local dest="$2"
    if [[ "$links_mode" == "1" ]]; then
        lns --verbose "$src" "$dest"
    else
        if [[ -d "$src" ]]; then
            rm -rf "$dest"
            mkdir -p "$dest"
            rsync -a "$src/" "$dest/"
            echo "  rsync: $src/ -> $dest/"
        else
            rm -f "$dest"
            mkdir -p "$(dirname "$dest")"
            cp -p "$src" "$dest"
            echo "  cp: $src -> $dest"
        fi
    fi
}

backup_item() {
    local src="$1"
    local dest="$2"

    rsync -a \
        --exclude='*.bdf' \
        --exclude='*.eot' \
        --exclude='*.fon' \
        --exclude='*.otf' \
        --exclude='*.pcf' \
        --exclude='*.ttc' \
        --exclude='*.ttf' \
        --exclude='*.woff' \
        --exclude='*.woff2' \
        "$src" "$dest"
}

is_wsl() {
    grep -qiE 'microsoft|wsl' /proc/version 2>/dev/null
}

treesitter_platform_id() {
    local os
    local arch
    local libc

    os=$(uname -s | tr '[:upper:]' '[:lower:]')
    arch=$(uname -m)
    if ldd --version 2>&1 | grep -qi musl; then
        libc="musl"
    else
        libc="glibc"
    fi

    echo "${os}-${arch}-${libc}"
}

glibc_version_id() {
    local version

    version=$(getconf GNU_LIBC_VERSION 2>/dev/null | awk '{print $2}')
    if [[ -z "$version" ]]; then
        version=$(ldd --version 2>&1 | grep -Eo '[0-9]+\.[0-9]+' | head -n 1)
    fi

    echo "$version"
}

glibc_version_num() {
    local version="$1"
    local major
    local minor

    major="${version%%.*}"
    minor="${version#*.}"
    minor="${minor%%[^0-9]*}"

    if [[ "$major" =~ ^[0-9]+$ && "$minor" =~ ^[0-9]+$ ]]; then
        echo $((major * 1000 + minor))
    else
        echo 0
    fi
}

prebuilt_exact_platform_ids() {
    local arch
    local glibc_version
    local glibc_id
    local el_id=""
    local id=""
    local id_like=""
    local version_id=""
    local platform_id=""

    arch=$(uname -m)
    if ldd --version 2>&1 | grep -qi musl; then
        echo "linux.$arch.musl"
        echo "linux-$arch-musl"
        return 0
    fi

    glibc_version=$(glibc_version_id)
    glibc_id="glibc${glibc_version//./p}"

    if [[ -r /etc/os-release ]]; then
        # shellcheck disable=SC1091
        . /etc/os-release
        id="${ID:-}"
        id_like="${ID_LIKE:-}"
        version_id="${VERSION_ID:-}"
        platform_id="${PLATFORM_ID:-}"
    fi

    if [[ "$platform_id" == platform:el* ]]; then
        el_id="${platform_id#platform:}"
    elif [[ " $id $id_like " == *" rhel "* || " $id $id_like " == *" centos "* || \
        " $id $id_like " == *" almalinux "* || " $id $id_like " == *" rocky "* || \
        " $id $id_like " == *" ol "* ]]; then
        el_id="el${version_id%%.*}"
    fi

    if [[ -n "$el_id" && -n "$glibc_version" ]]; then
        echo "$el_id.$arch.$glibc_id"
    fi
    if [[ -n "$glibc_version" ]]; then
        echo "linux.$arch.$glibc_id"
    fi
    echo "linux.$arch.glibc"
    echo "linux-$arch-glibc"
}

select_prebuilt_platform_dir() {
    local root_dir="$1"
    local candidate
    local dir
    local base
    local arch
    local host_glibc
    local host_glibc_num
    local build_glibc
    local build_glibc_num
    local best_dir=""
    local best_glibc_num=0

    for candidate in $(prebuilt_exact_platform_ids); do
        if [[ -d "$root_dir/$candidate" ]]; then
            echo "$root_dir/$candidate"
            return 0
        fi
    done

    arch=$(uname -m)
    host_glibc=$(glibc_version_id)
    host_glibc_num=$(glibc_version_num "$host_glibc")
    if [[ "$host_glibc_num" -eq 0 ]]; then
        return 1
    fi

    for dir in "$root_dir"/el*."$arch".glibc*p* "$root_dir"/linux."$arch".glibc*p*; do
        if [[ ! -d "$dir" ]]; then
            continue
        fi

        base=$(basename "$dir")
        if [[ "$base" =~ \.glibc([0-9]+)p([0-9]+)$ ]]; then
            build_glibc="${BASH_REMATCH[1]}.${BASH_REMATCH[2]}"
            build_glibc_num=$(glibc_version_num "$build_glibc")
            if [[ "$build_glibc_num" -le "$host_glibc_num" && "$build_glibc_num" -gt "$best_glibc_num" ]]; then
                best_glibc_num="$build_glibc_num"
                best_dir="$dir"
            fi
        fi
    done

    if [[ -n "$best_dir" ]]; then
        echo "$best_dir"
        return 0
    fi

    return 1
}

install_mode() {
    if [[ "$dev_mode" == "1" ]]; then
        echo "dev"
    elif [[ "$links_mode" == "1" ]]; then
        echo "links"
    else
        echo "copy"
    fi
}

install_prebuilt_binaries() {
    local root_dir="$repo_dir/pre_built"
    local src_dir
    local gz_file
    local dest_file
    local dest_bin_dir="$HOME/.local/bin"
    local dest_lib64_dir="$HOME/.local/lib64"

    echo "Installing pre-built binaries..."
    if [[ ! -d "$root_dir" ]]; then
        echo "  No pre_built directory found, skipping"
        return 0
    fi

    if ! command -v gzip >/dev/null; then
        echo "  Warning: gzip is not available; skipping pre-built binary installation"
        return 0
    fi

    if ! src_dir=$(select_prebuilt_platform_dir "$root_dir"); then
        echo "  No matching pre-built platform found, skipping"
        echo "  Checked: $(prebuilt_exact_platform_ids | paste -sd ' ' -)"
        return 0
    fi

    if [[ -d "$src_dir/bin" ]]; then
        mkdir -p "$dest_bin_dir"
        for gz_file in "$src_dir"/bin/*.gz; do
            if [[ ! -e "$gz_file" ]]; then
                continue
            fi

            dest_file="$dest_bin_dir/$(basename "${gz_file%.gz}")"
            gzip -cd "$gz_file" > "$dest_file"
            chmod 755 "$dest_file"
            echo "  gzip: $gz_file -> $dest_file"
        done
    fi

    if [[ -d "$src_dir/lib64" ]]; then
        mkdir -p "$dest_lib64_dir"
        for gz_file in "$src_dir"/lib64/*.gz; do
            if [[ ! -e "$gz_file" ]]; then
                continue
            fi

            dest_file="$dest_lib64_dir/$(basename "${gz_file%.gz}")"
            gzip -cd "$gz_file" > "$dest_file"
            chmod 644 "$dest_file"
            echo "  gzip: $gz_file -> $dest_file"
        done
    fi

    patch_prebuilt_binary_rpaths "$dest_bin_dir"
    check_prebuilt_binary_dependencies "$dest_bin_dir"
    echo "  Installed: $src_dir/ -> $HOME/.local/"
}

patch_prebuilt_binary_rpaths() {
    local dest_bin_dir="$1"
    local patchelf="$dest_bin_dir/patchelf"
    local binary
    local rpath='$ORIGIN/../lib64:$ORIGIN/../lib'

    if [[ ! -x "$patchelf" ]]; then
        echo "  Warning: vendored patchelf not installed; skipping pre-built binary RPATH patching"
        return 0
    fi

    for binary in "$dest_bin_dir"/*; do
        if [[ ! -f "$binary" || ! -x "$binary" ]]; then
            continue
        fi
        if [[ "$binary" == "$patchelf" ]]; then
            continue
        fi

        if "$patchelf" --print-interpreter "$binary" >/dev/null 2>&1; then
            "$patchelf" --set-rpath "$rpath" "$binary" || {
                echo "  Warning: failed to patch RPATH for $binary"
                continue
            }
            echo "  patchelf: set RPATH on $binary to $rpath"
        fi
    done
}

check_prebuilt_binary_dependencies() {
    local dest_bin_dir="$1"
    local binary
    local missing=0

    if ! command -v ldd >/dev/null; then
        echo "  Warning: ldd is not available; skipping pre-built dependency check"
        return 0
    fi

    for binary in "$dest_bin_dir"/*; do
        if [[ ! -f "$binary" || ! -x "$binary" ]]; then
            continue
        fi

        if ldd "$binary" 2>/dev/null | grep -q 'not found'; then
            echo "  Warning: missing shared libraries for $binary"
            ldd "$binary" 2>/dev/null | awk '/not found/ { print "    " $1 }'
            missing=1
        fi
    done

    if [[ "$missing" == "0" ]]; then
        echo "  Shared library check OK"
    fi
}

install_fonts() {
    local vendor_fonts_dir="$repo_dir/fonts"
    local user_fonts_dir="$HOME/.local/share/fonts"
    local tmp_font_dir=""

    if [[ ! -d "$vendor_fonts_dir" ]]; then
        echo "Installing fonts..."
        echo "  No vendored fonts directory found, skipping"
        return 0
    fi

    if ! command -v unzip >/dev/null; then
        echo "Installing fonts..."
        echo "  Warning: unzip is not available; skipping vendored font installation"
        return 0
    fi

    echo "Installing fonts..."
    mkdir -p "$user_fonts_dir"

    extract_font_zip() {
        local zip_path="$1"
        local font_file

        echo "  Extracting: $zip_path -> $user_fonts_dir/"
        while IFS= read -r font_file; do
            unzip -o -j "$zip_path" "$font_file" -d "$user_fonts_dir" >/dev/null
        done < <(unzip -Z1 "$zip_path" | grep -Ei '\.(ttf|otf|pcf|bdf)(\.gz)?$')
    }

    local font_zip
    for font_zip in "$vendor_fonts_dir"/*.zip; do
        if [[ ! -e "$font_zip" ]]; then
            continue
        fi

        extract_font_zip "$font_zip"
    done

    local first_part
    local split_base
    local rejoined_zip
    for first_part in "$vendor_fonts_dir"/*.zip.part-000; do
        if [[ ! -e "$first_part" ]]; then
            continue
        fi

        if [[ -z "$tmp_font_dir" ]]; then
            tmp_font_dir=$(mktemp -d /tmp/dotfiles-fonts.XXXXXX)
        fi

        split_base="${first_part%.part-000}"
        rejoined_zip="$tmp_font_dir/$(basename "$split_base")"
        echo "  Rejoining: $split_base.part-* -> $rejoined_zip"
        cat "$split_base".part-* > "$rejoined_zip"
        extract_font_zip "$rejoined_zip"
    done

    if [[ -n "$tmp_font_dir" ]]; then
        rm -rf "$tmp_font_dir"
    fi

    if command -v mkfontscale >/dev/null; then
        mkfontscale "$user_fonts_dir" >/dev/null 2>&1 || \
            echo "  Warning: mkfontscale failed for $user_fonts_dir"
    fi

    if command -v mkfontdir >/dev/null; then
        mkfontdir "$user_fonts_dir" >/dev/null 2>&1 || \
            echo "  Warning: mkfontdir failed for $user_fonts_dir"
    fi

    if command -v fc-cache >/dev/null; then
        fc-cache -f "$user_fonts_dir" >/dev/null 2>&1 || \
            echo "  Warning: fc-cache failed for $user_fonts_dir"
    else
        echo "  Warning: fc-cache is not available; fontconfig cache was not refreshed"
    fi

    if is_wsl; then
        echo "  WSL note: Linux GUI apps use these fonts through fontconfig."
        echo "  WSL note: Windows Terminal needs fonts installed on the Windows side."
    fi
}

install_treesitter_parsers() {
    local platform
    local src_dir
    local dest_dir

    platform=$(treesitter_platform_id)
    src_dir="$repo_dir/treesitter/prebuilt/$platform"
    dest_dir="$HOME/.local/share/nvim/tree-sitter-parsers"

    echo "Installing Tree-sitter parsers..."
    if [[ ! -d "$src_dir/parser" ]]; then
        echo "  No prebuilt parsers for $platform, skipping"
        return 0
    fi

    mkdir -p "$dest_dir/parser"
    rsync -a "$src_dir/parser/" "$dest_dir/parser/"
    if [[ -d "$src_dir/queries" ]]; then
        mkdir -p "$dest_dir/queries"
        rsync -a "$src_dir/queries/" "$dest_dir/queries/"
    fi
    if [[ -d "$src_dir/build-info" ]]; then
        mkdir -p "$dest_dir/build-info"
        rsync -a "$src_dir/build-info/" "$dest_dir/build-info/"
    fi
    if [[ -d "$src_dir/parser-info" ]]; then
        mkdir -p "$dest_dir/parser-info"
        rsync -a "$src_dir/parser-info/" "$dest_dir/parser-info/"
    fi
    if [[ -d "$src_dir/registry" ]]; then
        mkdir -p "$dest_dir/registry"
        rsync -a "$src_dir/registry/" "$dest_dir/registry/"
    fi

    echo "  Installed: $src_dir/ -> $dest_dir/"
}

install_nvim_treesitter_vendor() {
    local src_root
    local dest_root

    src_root="$repo_dir/treesitter/vendor"
    dest_root="$HOME/.local/share/nvim/dotfiles/vendor"

    echo "Installing vendored nvim-treesitter..."
    if [[ ! -d "$src_root/nvim-treesitter" || ! -d "$src_root/treesitter-parser-registry" ]]; then
        echo "  Vendored nvim-treesitter is missing, skipping"
        return 0
    fi

    mkdir -p "$dest_root"
    rsync -a --delete --exclude .git "$src_root/nvim-treesitter/" "$dest_root/nvim-treesitter/"
    rsync -a --delete --exclude .git "$src_root/treesitter-parser-registry/" "$dest_root/treesitter-parser-registry/"
    echo "  Installed: $src_root/ -> $dest_root/"
}

# --- Restore backup ---

if [[ -n "$restore_backup" ]]; then
    if [[ ! -d "$restore_backup" ]]; then
        echo "Error: Backup directory not found: $restore_backup"
        exit 1
    fi

    echo "Restoring dotfiles from backup: $restore_backup"
    echo ""
    echo "Removing current dotfiles..."
    # Handle .config/bash specially to preserve user layer dirs
    if [[ -L ~/.config/bash ]]; then
        rm -f ~/.config/bash
    elif [[ -d ~/.config/bash ]]; then
        rm -fr ~/.config/bash/global
        rm -f ~/.config/bash/functions.sh ~/.config/bash/README.md ~/.config/bash/bashrc
    fi
    for item in ~/.bashrc ~/.bash_profile ~/.bash_login ~/.profile ~/.vimrc ~/.tmux.conf ~/.editorconfig ~/.tmux ~/.vim \
        ~/.config/nvim ~/.config/tmux ~/.config/editorconfig ~/.config/starship ~/.config/vim; do
        if [[ -e "$item" || -L "$item" ]]; then
            echo "  Removing: $item"
            if [[ -L "$item" ]]; then rm -f "$item"; else rm -rf "$item"; fi
        fi
    done

    echo ""
    echo "Restoring files from backup..."
    if ls -A "$restore_backup" 2>/dev/null | grep -q .; then
        cd "$restore_backup"
        cp -rPp . "$HOME/"
        echo ""
        echo "Backup restored successfully!"
        echo ""
        echo "Restored from: $restore_backup"
    else
        echo "Error: Backup directory is empty"
        exit 1
    fi

    exit 0
fi

# --- Main ---

script_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
repo_dir="$script_dir"
echo "Dotfiles repo base directory: $repo_dir"

if [[ -n "$post_install_hook" ]]; then
    if [[ ! -r "$post_install_hook" ]]; then
        echo "Error: Post-install hook is not readable: $post_install_hook"
        exit 1
    fi
    post_install_hook_dir=$(cd "$(dirname "$post_install_hook")" && pwd)
    post_install_hook="$post_install_hook_dir/$(basename "$post_install_hook")"
    unset post_install_hook_dir
fi

echo "Changing directory to ~"
cd ~

# Backup existing dotfiles (skip in dev mode or with --no-backup)
if [[ "$dev_mode" != "1" && "$no_backup" != "1" ]]; then
    backup_dir=$(mkdirn "dotfiles_backups/backup")
    echo "Making backups in: $backup_dir"

    for x in \
        .bashrc \
        .bash_profile \
        .bash_login \
        .profile \
        .vimrc \
        .vim \
        .tmux \
        .tmux.conf \
        .editorconfig \
        .config/vim \
        .config/nvim \
        .config/bash/global \
        .config/bash/functions.sh \
        .config/bash/README.md \
        .config/bash/bashrc \
        .config/tmux \
        .config/starship \
        .config/editorconfig; do

        if [[ ! -e "$x" && ! -L "$x" ]]; then
            continue
        fi

        if [[ -L "$x" ]]; then
            link_target=$(readlink "$x")
            if [[ "$link_target" == "$repo_dir"* ]] ||
                [[ -e "$x" && "$(realpath "$x" 2>/dev/null)" == "$repo_dir"* ]]; then
                echo "  Skipping (points to repo): $x"
                continue
            fi
        fi

        echo "  Backing up: $x"
        mkdir -p "$backup_dir/$(dirname "$x")"
        backup_item "$x" "$backup_dir/$x"
    done

    echo ""
fi

mkdir -p .config

if [[ "$dev_mode" == "1" ]]; then
    for config_dir in \
        nvim \
        vim \
        tmux \
        starship \
        editorconfig; do

        rm -fr .config/$config_dir
        lns --verbose $repo_dir/$config_dir .config/$config_dir
    done

    # Bash: only symlink repo-managed files, preserve user layer dirs.
    # If .config/bash is an old directory-level symlink, replace it with
    # a real directory (copying user layer dirs out first).
    if [[ -L .config/bash ]]; then
        # Save user layer dirs before removing the symlink
        for layer in corp site project user; do
            if [[ -d .config/bash/$layer ]]; then
                cp -rPp .config/bash/$layer /tmp/dotfiles_bash_${layer}_$$
            fi
        done
        rm -f .config/bash
        mkdir -p .config/bash
        for layer in corp site project user; do
            if [[ -d /tmp/dotfiles_bash_${layer}_$$ ]]; then
                mv /tmp/dotfiles_bash_${layer}_$$ .config/bash/$layer
            fi
        done
    else
        mkdir -p .config/bash
        # Remove only repo-managed items
        if [[ -L .config/bash/global ]]; then rm -f .config/bash/global; else rm -fr .config/bash/global; fi
        rm -f .config/bash/functions.sh .config/bash/README.md .config/bash/bashrc
    fi
    lns --verbose $repo_dir/bash/global .config/bash/global
    lns --verbose $repo_dir/bash/functions.sh .config/bash/functions.sh
    lns --verbose $repo_dir/bash/README.md .config/bash/README.md
    lns --verbose $repo_dir/bash/bashrc .config/bash/bashrc
    lns --verbose .config/bash/bashrc .bashrc
    lns --verbose .config/bash/bashrc .bash_profile
    lns --verbose .config/bash/bashrc .bash_login
    lns --verbose .config/bash/bashrc .profile
    lns --verbose .config/vim/vimrc .vimrc
    lns --verbose .config/vim/vim .vim
    lns --verbose .config/tmux/tmux.conf .tmux.conf
    lns --verbose .config/tmux/tmux .tmux
    lns --verbose .config/editorconfig/editorconfig .editorconfig
else
    ### BASH ###
    rm -f .bashrc .bash_profile .bash_login .profile
    # If .config/bash is an old directory-level symlink, replace it with
    # a real directory (copying user layer dirs out first).
    if [[ -L .config/bash ]]; then
        for layer in corp site project user; do
            if [[ -d .config/bash/$layer ]]; then
                cp -rPp .config/bash/$layer /tmp/dotfiles_bash_${layer}_$$
            fi
        done
        rm -f .config/bash
        mkdir -p .config/bash
        for layer in corp site project user; do
            if [[ -d /tmp/dotfiles_bash_${layer}_$$ ]]; then
                mv /tmp/dotfiles_bash_${layer}_$$ .config/bash/$layer
            fi
        done
    else
        mkdir -p .config/bash
        if [[ -L .config/bash/global ]]; then rm -f .config/bash/global; else rm -fr .config/bash/global; fi
        rm -f .config/bash/functions.sh .config/bash/README.md .config/bash/bashrc
    fi
    inst $repo_dir/bash/global .config/bash/global
    inst $repo_dir/bash/functions.sh .config/bash/functions.sh
    inst $repo_dir/bash/README.md .config/bash/README.md
    inst $repo_dir/bash/bashrc .config/bash/bashrc
    lns --verbose .config/bash/bashrc .bashrc
    lns --verbose .config/bash/bashrc .bash_profile
    lns --verbose .config/bash/bashrc .bash_login
    lns --verbose .config/bash/bashrc .profile

    ### NEOVIM ###
    rm -fr .config/nvim
    mkdir -p .config/nvim
    mkdir -p .config/nvim/after/lsp
    mkdir -p .config/nvim/after/ftplugin
    mkdir -p .config/nvim/lsp
    mkdir -p .config/nvim/lua/custom/plugins
    inst $repo_dir/nvim/lua/custom/plugins/init.lua \
        .config/nvim/lua/custom/plugins/init.lua
    inst $repo_dir/nvim/lua/kickstart .config/nvim/lua/kickstart
    inst $repo_dir/nvim/doc .config/nvim/doc
    inst $repo_dir/nvim/lazy-lock.json .config/nvim/lazy-lock.json
    inst $repo_dir/nvim/README.md .config/nvim/README.md
    inst $repo_dir/nvim/LICENSE.md .config/nvim/LICENSE.md
    inst $repo_dir/nvim/init.lua .config/nvim/init.lua
    for x in $repo_dir/nvim/lsp/*; do
        inst $x .config/nvim/lsp/$(basename $x)
    done
    if compgen -G "$repo_dir/nvim/lua/kickstart/plugins/*" > /dev/null; then
        for x in $repo_dir/nvim/lua/kickstart/plugins/*; do
            inst $x .config/nvim/lua/kickstart/plugins/$(basename $x)
        done
    fi

    ### VIM ###
    rm -f .vimrc
    rm -fr .vim
    rm -fr .config/vim
    mkdir -p .config/vim/vim/pack/vendor/start
    mkdir -p .config/vim/vim/pack/vendor/opt
    for start_or_opt in start opt; do
        for plugin_dir in $repo_dir/vim/vim/pack/vendor/$start_or_opt/*; do
            inst $plugin_dir \
                .config/vim/vim/pack/vendor/$start_or_opt/$(basename $plugin_dir)
        done
    done
    inst $repo_dir/vim/vimrc .config/vim/vimrc
    lns --verbose .config/vim/vimrc .vimrc

    ### TMUX ###
    # All tmux plugins are vendored in the repo
    rm -f .tmux.conf
    rm -fr .tmux
    rm -fr .config/tmux
    mkdir -p .config/tmux/tmux/plugins
    for plugin_dir in $repo_dir/tmux/vendor/plugins/*; do
        inst $plugin_dir \
            .config/tmux/tmux/plugins/$(basename $plugin_dir)
    done
    inst $repo_dir/tmux/tmux.conf .config/tmux/tmux.conf
    inst $repo_dir/tmux/tmux-3col-layout.sh .config/tmux/tmux-3col-layout.sh
    lns --verbose .config/tmux/tmux.conf .tmux.conf
    lns --verbose .config/tmux/tmux .tmux

    rm -fr .editorconfig
    rm -fr .config/editorconfig
    mkdir -p .config/editorconfig
    inst $repo_dir/editorconfig/editorconfig .config/editorconfig/editorconfig
    lns --verbose .config/editorconfig/editorconfig .editorconfig

    rm -fr .config/starship
    mkdir -p .config/starship
    inst $repo_dir/starship/starship.toml .config/starship/starship.toml
fi

if [[ "$no_fonts" != "1" ]]; then
    install_fonts
else
    echo "Installing fonts..."
    echo "  Skipped (--no-fonts)"
fi

install_prebuilt_binaries

install_nvim_treesitter_vendor
install_treesitter_parsers

# Install git hooks for repo development only.
if [[ "$dev_mode" == "1" ]]; then
    echo "Installing git hooks..."
    if [[ -d "$repo_dir/hooks" ]]; then
        for hook in "$repo_dir/hooks"/*; do
            if [[ -f "$hook" && ! "$hook" =~ README ]]; then
                hook_name=$(basename "$hook")
                cp "$hook" "$repo_dir/.git/hooks/$hook_name"
                chmod +x "$repo_dir/.git/hooks/$hook_name"
                echo "  Installed: $hook_name"
            fi
        done
    else
        echo "  No hooks directory found, skipping"
    fi
else
    echo "Installing git hooks..."
    echo "  Skipped (use --dev for repo development hooks)"
fi

if [[ -n "$post_install_hook" ]]; then
    echo "Running post-install hook: $post_install_hook"
    DOTFILES_REPO="$repo_dir" \
        DOTFILES_HOME="$HOME" \
        DOTFILES_MODE="$(install_mode)" \
        DOTFILES_NO_BACKUP="$no_backup" \
        DOTFILES_NO_FONTS="$no_fonts" \
        bash "$post_install_hook"
fi

# Allow for extra layers of installation scripting. Use source so that variables from
# this execution environment are available.
for layer in corp site project user; do
    install_script="$HOME/.config/bash/$layer/install.sh"
    if [[ -r "$install_script" ]]; then
        echo "Sourcing '$install_script' ..."
        source $install_script
    fi
done
