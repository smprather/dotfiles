#!/usr/bin/env python3
# Download the latest YARA-Forge full ruleset and vendor it into the repo.
#
# Stores: yara/yara-rules-full.yar.bz2  (bzip2-compressed .yar file)
#         yara/release-tag.txt           (release tag for reference)
#
# Usage:
#   ./update_yara_forge_rules_full             # latest release
#   ./update_yara_forge_rules_full --tag 20260517   # specific release
#
# After running:
#   git add yara/yara-rules-full.yar.bz2 yara/release-tag.txt
#   git commit -m "chore: update YARA-Forge full rules to <tag>"

import argparse
import bz2
import json
import os
import shutil
import sys
import tempfile
import zipfile
from urllib.request import Request, urlopen

_REPO = os.path.dirname(os.path.abspath(__file__))
_YARA_DIR = os.path.join(_REPO, "yara")
_RULES_BZ2 = os.path.join(_YARA_DIR, "yara-rules-full.yar.bz2")
_TAG_FILE = os.path.join(_YARA_DIR, "release-tag.txt")
_API_LATEST = "https://api.github.com/repos/YARAHQ/yara-forge/releases/latest"
_ZIP_URL = "https://github.com/YARAHQ/yara-forge/releases/download/{tag}/yara-forge-rules-full.zip"
_ZIP_MEMBER = "packages/full/yara-rules-full.yar"


def _fetch_json(url):
    req = Request(url, headers={"User-Agent": "dotfiles-update-yara/1.0",
                                "Accept": "application/vnd.github+json"})
    with urlopen(req, timeout=60) as r:
        return json.loads(r.read())


def _download(url, dest):
    print(f"  GET {url}")
    req = Request(url, headers={"User-Agent": "dotfiles-update-yara/1.0"})
    with urlopen(req, timeout=120) as r:
        with open(dest, "wb") as f:
            while True:
                chunk = r.read(65536)
                if not chunk:
                    break
                f.write(chunk)


def main():
    ap = argparse.ArgumentParser(description="Vendor YARA-Forge full rules into the repo")
    ap.add_argument("--tag", help="Specific release tag (default: latest)")
    args = ap.parse_args()

    if args.tag:
        tag = args.tag
    else:
        print("Fetching latest YARA-Forge release...")
        meta = _fetch_json(_API_LATEST)
        tag = meta["tag_name"]
        print(f"  Latest: {tag}")

    current_tag = open(_TAG_FILE).read().strip() if os.path.exists(_TAG_FILE) else ""
    if current_tag == tag:
        print(f"Already at {tag} — nothing to do.")
        return

    zip_url = _ZIP_URL.format(tag=tag)
    with tempfile.TemporaryDirectory(prefix="yara-forge-") as tmp:
        zip_path = os.path.join(tmp, "rules-full.zip")
        print(f"Downloading {tag} rules...")
        _download(zip_url, zip_path)

        print(f"  Extracting {_ZIP_MEMBER}...")
        with zipfile.ZipFile(zip_path) as zf:
            raw = zf.read(_ZIP_MEMBER)

        print(f"  Rules size: {len(raw) // 1024 // 1024} MB uncompressed")

        os.makedirs(_YARA_DIR, exist_ok=True)
        bz2_path = _RULES_BZ2 + ".tmp"
        with bz2.open(bz2_path, "wb", compresslevel=9) as f:
            f.write(raw)
        os.replace(bz2_path, _RULES_BZ2)

        with open(_TAG_FILE, "w") as f:
            f.write(tag + "\n")

    compressed_kb = os.path.getsize(_RULES_BZ2) // 1024
    print(f"  Compressed size: {compressed_kb} KB")
    print(f"\nVendored: {_RULES_BZ2}")
    print(f"Tag:      {tag}")
    print(f"\nCommit with:")
    print(f"  git add yara/yara-rules-full.yar.bz2 yara/release-tag.txt")
    print(f"  git commit -m 'chore: update YARA-Forge full rules to {tag}'")


if __name__ == "__main__":
    main()
