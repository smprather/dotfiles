    return 0 2>/dev/null || exit 0
fi
DOTFILES_BASHRC_SOURCED=1

# Start with a clean slate: clear all aliases and functions.
# Preserve inherited PATH when present; otherwise use a minimal fallback.
if [[ -z "${PATH:-}" ]]; then
    export PATH="/usr/local/bin:/bin:/usr/bin:/usr/sbin"
fi
unalias -a
unset -f $(declare -F | awk '{print $3}')

export USER=$(whoami)
export HOME=$(getent passwd $USER | cut -d: -f6)

