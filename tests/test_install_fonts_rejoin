#!/usr/bin/env python3
"""Unit test for split-zip rejoining in install.py.

Creates a minimal valid zip, splits it into parts, runs install_fonts
against a synthetic fonts dir, and verifies the font file lands in the
dest dir — without requiring the real vendored font archives.
"""
from __future__ import print_function

import io
import os
import shutil
import sys
import tempfile
import zipfile

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
import install


def make_split_font_zip(fonts_dir, base_name, chunk_size=20):
    """Write a valid zip with one .ttf entry, split into chunk_size-byte parts."""
    buf = io.BytesIO()
    with zipfile.ZipFile(buf, "w", compression=zipfile.ZIP_STORED) as zf:
        zf.writestr("dummy.ttf", b"FAKE TTF DATA " * 10)
    data = buf.getvalue()

    i = 0
    offset = 0
    while offset < len(data):
        part_path = os.path.join(fonts_dir, "{}.part-{:03d}".format(base_name, i))
        with open(part_path, "wb") as fh:
            fh.write(data[offset:offset + chunk_size])
        offset += chunk_size
        i += 1

    return i  # number of parts written


def run():
    repo_dir = tempfile.mkdtemp(prefix="test-fonts-repo.")
    tmp_home = tempfile.mkdtemp(prefix="test-fonts-home.")
    try:
        fonts_dir = os.path.join(repo_dir, "fonts")
        os.makedirs(fonts_dir)
        n_parts = make_split_font_zip(fonts_dir, "TestFont.zip", chunk_size=20)
        assert n_parts >= 2, "Need at least 2 parts to exercise the rejoin path"

        install.install_fonts(repo_dir, tmp_home)

        user_fonts_dir = os.path.join(tmp_home, ".local", "share", "fonts")
        installed = os.listdir(user_fonts_dir) if os.path.isdir(user_fonts_dir) else []
        assert "dummy.ttf" in installed, \
            "Expected dummy.ttf in {}; got: {}".format(user_fonts_dir, installed)

        print("PASS: split-zip rejoin extracted {} parts -> dummy.ttf".format(n_parts))
    finally:
        shutil.rmtree(repo_dir, ignore_errors=True)
        shutil.rmtree(tmp_home, ignore_errors=True)


if __name__ == "__main__":
    run()
