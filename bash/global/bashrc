    export NVM_DIR="$HOME/.nvm"
    [[ -s "$NVM_DIR/nvm.sh" ]] && source "$NVM_DIR/nvm.sh"
    [[ -s "$NVM_DIR/bash_completion" ]] && source "$NVM_DIR/bash_completion"
fi

# Add common user-level bins used by local tooling.
# NVM_BIN : Node.js toolchain
for potential_bin_dir in \
    /usr/local/bin \
    $NVM_BIN \
    ~/.cargo/bin \
    ~/.venv/bin \
    ~/.opencode/bin \
    ~/node_modules/.bin \
    ~/go/bin \
    ~/.local/bin; do
    path_prepend_if_dir $potential_bin_dir
done

# Exit here if not interactive
