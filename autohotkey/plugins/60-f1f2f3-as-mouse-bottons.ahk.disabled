; F1/F2/F3 mouse button remap plugin.
; Enable by adding "f1f2f3_as_mouse_bottons" to dotkeys_config.toml.

#HotIf WinActive("ahk_exe mspaint.exe") or WinActive("ahk_exe etxc.exe") or WinActive("ahk_exe wezterm-gui.exe")
; Make F1 just like LMB
F1::
{
    Send("{LButton Down}")
    KeyWait("F1")
    Send("{LButton Up}")
}

F2::
{
    Send("{RButton Down}")
    KeyWait("F2")
    Send("{RButton Up}")
}

F3::
{
    Send("{LButton 2}")
    Sleep(500)
    Send("{RButton}")
}

#HotIf
