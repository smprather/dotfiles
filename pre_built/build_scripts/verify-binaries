#!/usr/bin/env python3
"""
verify-binaries — compare bundled .bz2 binaries against official upstream releases.

Downloads each tool's official release binary, applies our bundling transformation
(strip → patchelf RPATH for dynamic ELFs), and compares SHA-256 against the
decompressed bundled binary.

PASS  = byte-for-byte match with upstream release (after strip + patchelf)
FAIL  = hash mismatch — investigate; could be wrong variant or tampering
SKIP  = no public binary release (source builds, dev versions, custom builds)
ERROR = download failed or archive extraction error

Usage:
  ./verify-binaries [TOOL ...] [--keep] [-v]

Options:
  TOOL          Tool name(s) to verify. Default: all registered.
  --keep        Keep the temp directory after exit (for debugging).
  -v/--verbose  Print each download/extract/strip step.
"""

