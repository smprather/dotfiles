#!/usr/bin/python3
import os
import sys

if sys.version_info < (3, 6):
    version = ".".join(str(part) for part in sys.version_info[:3])
    print("Error: This installer requires python3 >= 3.6; found {}.".format(version), file=sys.stderr)
    raise SystemExit(1)

# Vendor path: installer_vendor/ next to this script
_VENDOR_DIR = os.path.join(os.path.dirname(os.path.abspath(__file__)), "installer_vendor")
if os.path.isdir(_VENDOR_DIR):
    sys.path.insert(0, _VENDOR_DIR)
    if sys.version_info < (3, 7):
        sys.path.insert(0, os.path.join(_VENDOR_DIR, "py36"))

try:
    from rich.console import Console as _RichConsole
    from rich.table import Table as _RichTable
    from rich.progress import (
        Progress as _RichProgress,
        BarColumn, TextColumn, TimeElapsedColumn, MofNCompleteColumn,
    )
    _RICH = True
    _console = _RichConsole(highlight=False)
except Exception:
    _RICH = False
    _console = None


def _vprint(msg):
    """Print only when rich is unavailable (suppresses per-file noise when rich shows progress)."""
    if not _RICH:
        print(msg)


def _progress(description, total):
    """Return a started rich Progress context for `total` items, or None when rich unavailable."""
    if not _RICH:
        return None, None
    p = _RichProgress(
        TextColumn("[cyan]{task.description}"),
        BarColumn(),
        MofNCompleteColumn(),
        TimeElapsedColumn(),
        console=_console,
        transient=True,
    )
    p.start()
    task = p.add_task(description, total=total)
    return p, task


def _section(title):
    """Print a section heading. Rich: styled bold; plain: plain print."""
    if _RICH:
        _console.print("[bold]{}[/bold]".format(title))
    else:
        print(title)

