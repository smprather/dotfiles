#!/usr/bin/python3
"""
import-portable-python: package a portable Python build directory into the
dotfiles pre_built tree.

Usage:
    ./import-portable-python <portable-dir> [--platform PLATFORM] [--dry-run]

<portable-dir> is a directory containing install.sh, README.md, and local/.
Example: portable-python-3.14.4-el8-clang23

The output archive is placed at:
    <repo>/pre_built/<platform>/<basename>.tar.bz2

Platform auto-detection (used when --platform is not given):
  - arch: uname -m
  - glibc version: getconf GNU_LIBC_VERSION or ldd --version
  - OS family: /etc/os-release PLATFORM_ID / ID + ID_LIKE
  Produces a platform string like "el8.x86_64.glibc2p28".

Python version is read from <portable-dir>/local/bin/python3.x --version, or
parsed from the directory name as a fallback.
"""
from __future__ import print_function

import argparse
import os
import re
import subprocess
import sys
import tarfile


def eprint(*args):
    print(*args, file=sys.stderr)


def die(msg):
    eprint("error: {}".format(msg))
    sys.exit(1)


# ---------------------------------------------------------------------------
# Platform detection (mirrors logic in dotfiles/install)
# ---------------------------------------------------------------------------

def _find_tool(*candidates):
    for path in candidates:
        if os.path.isfile(path) and os.access(path, os.X_OK):
            return path
    return None


_UNAME   = _find_tool("/usr/bin/uname", "/bin/uname")
_LDD     = _find_tool("/usr/bin/ldd", "/lib64/ld-linux-x86-64.so.2")
_GETCONF = _find_tool("/usr/bin/getconf")


def _run_output(*cmd):
    proc = subprocess.run(list(cmd), stdout=subprocess.PIPE, stderr=subprocess.PIPE)
    return proc.stdout.decode("utf-8", "replace").strip()


def detect_arch():
    if not _UNAME:
        die("uname not found")
    return _run_output(_UNAME, "-m")


def detect_glibc_version():
    if _GETCONF:
        text = _run_output(_GETCONF, "GNU_LIBC_VERSION")
        parts = text.split()
        if len(parts) >= 2:
            return parts[1]
    if _LDD:
        proc = subprocess.run([_LDD, "--version"], stdout=subprocess.PIPE, stderr=subprocess.STDOUT)
        m = re.search(rb"[0-9]+\.[0-9]+", proc.stdout)
        if m:
            return m.group(0).decode("ascii")
    return ""


def ldd_is_musl():
    if not _LDD:
        return False
    proc = subprocess.run([_LDD, "--version"], stdout=subprocess.PIPE, stderr=subprocess.STDOUT)
    return b"musl" in proc.stdout.lower()


def read_os_release():
    data = {}
    try:
        with open("/etc/os-release") as fh:
            for line in fh:
                line = line.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                key, value = line.split("=", 1)
                data[key] = value.strip().strip('"')
    except IOError:
        pass
    return data


def detect_platform():
    arch = detect_arch()

    if ldd_is_musl():
        return "linux.{}.musl".format(arch)

    glibc_ver = detect_glibc_version()
    glibc_id  = "glibc{}".format(glibc_ver.replace(".", "p")) if glibc_ver else "glibc"

    osr         = read_os_release()
    distro_id   = osr.get("ID", "")
    id_like     = osr.get("ID_LIKE", "")
    version_id  = osr.get("VERSION_ID", "")
    platform_id = osr.get("PLATFORM_ID", "")
    el_id       = ""

    if platform_id.startswith("platform:el"):
        el_id = platform_id[len("platform:"):]
    elif any(x in (" " + distro_id + " " + id_like + " ")
             for x in (" rhel ", " centos ", " almalinux ", " rocky ", " ol ")):
        el_id = "el{}".format(version_id.split(".", 1)[0])

    if el_id:
        return "{}.{}.{}".format(el_id, arch, glibc_id)
    return "linux.{}.{}".format(arch, glibc_id)


# ---------------------------------------------------------------------------
# Python version detection
# ---------------------------------------------------------------------------

def detect_python_version(portable_dir):
    """Run python3.x from local/bin to get the version string."""
    bin_dir = os.path.join(portable_dir, "local", "bin")
    if os.path.isdir(bin_dir):
        for name in sorted(os.listdir(bin_dir)):
            if re.match(r"^python3(\.\d+)?$", name):
                binary = os.path.join(bin_dir, name)
                if os.access(binary, os.X_OK):
                    out = _run_output(binary, "--version")
                    m = re.search(r"Python\s+([0-9]+\.[0-9]+\.[0-9]+)", out)
                    if m:
                        return m.group(1)
    # Fallback: parse from directory basename
    basename = os.path.basename(os.path.abspath(portable_dir))
    m = re.search(r"portable-python-([0-9]+\.[0-9]+\.[0-9]+)", basename)
    if m:
        return m.group(1)
    return None


# ---------------------------------------------------------------------------
# Archive construction
# ---------------------------------------------------------------------------

def make_archive(portable_dir, dest_path, dry_run):
    basename   = os.path.basename(os.path.abspath(portable_dir))
    parent_dir = os.path.dirname(os.path.abspath(portable_dir))

    print("source dir : {}".format(portable_dir))
    print("archive    : {}".format(dest_path))

    if dry_run:
        print("[dry-run] would create {}".format(dest_path))
        return

    dest_dir = os.path.dirname(dest_path)
    if dest_dir:
        os.makedirs(dest_dir, exist_ok=True)

    tmp_path = dest_path + ".tmp"
    try:
        with tarfile.open(tmp_path, "w:bz2") as tf:
            tf.add(portable_dir, arcname=basename)
        os.rename(tmp_path, dest_path)
        tmp_path = None
    finally:
        if tmp_path and os.path.exists(tmp_path):
            os.unlink(tmp_path)

    size_mb = os.path.getsize(dest_path) / 1024 / 1024
    print("created    : {} ({:.1f} MB)".format(dest_path, size_mb))


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        description="Package a portable Python build dir into dotfiles pre_built/.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("portable_dir",
                        help="path to the portable-python-X.Y.Z-... directory")
    parser.add_argument("--platform", default=None,
                        help="override platform string (default: auto-detect)")
    parser.add_argument("--output", default=None,
                        help="write archive to this path instead of the default repo location")
    parser.add_argument("--dry-run", action="store_true",
                        help="print what would be done without creating the archive")
    args = parser.parse_args()

    portable_dir = os.path.abspath(args.portable_dir)
    if not os.path.isdir(portable_dir):
        die("not a directory: {}".format(portable_dir))
    if not os.path.isfile(os.path.join(portable_dir, "install.sh")):
        die("no install.sh in {}: does not look like a portable-python directory".format(portable_dir))

    # Python version
    py_version = detect_python_version(portable_dir)
    if py_version:
        print("python     : {}".format(py_version))
    else:
        eprint("warning: could not determine Python version; using directory name")

    # Platform
    platform = args.platform or detect_platform()
    print("platform   : {}".format(platform))

    # Output path
    if args.output:
        dest_path = os.path.abspath(args.output)
    else:
        script_dir = os.path.dirname(os.path.abspath(__file__))
        repo_dir   = os.path.dirname(script_dir)          # pre_built/
        repo_dir   = os.path.dirname(repo_dir)            # repo root
        basename   = os.path.basename(portable_dir)
        dest_path  = os.path.join(repo_dir, "pre_built", platform,
                                  "{}.tar.bz2".format(basename))

    make_archive(portable_dir, dest_path, args.dry_run)

    if not args.dry_run:
        print()
        print("Next steps:")
        print("  cd <repo>")
        print("  ./strip_all_elf_binaries   # skips BOLT-optimized portable-python archives")
        print("  git add pre_built/{}/{}".format(platform,
              os.path.basename(portable_dir) + ".tar.bz2"))
        print("  git commit")


if __name__ == "__main__":
    main()
