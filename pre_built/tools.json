{
  "_comment": "Tool registry for the dotfiles installer. See pre_built/ADDING_BINARIES.md for the workflow.",
  "_schema": {
    "bins":     "List of bin/*.bz2 stems (without .bz2) owned by this tool.",
    "libs":     "List of lib64/*.bz2 stems exclusively owned by this tool. Omit or leave empty for libs shared by multiple tools — those are always installed. Exclusively-owned libs are skipped when the tool is not selected.",
    "optional": "If true, not installed by default. User must opt in with --add-tools."
  },

  "bash":        {"bins": ["bash"]},
  "bat":         {"bins": ["bat"]},
  "broot":       {"bins": ["broot"]},
  "btm":         {"bins": ["btm"]},
  "btop":        {"bins": ["btop"]},
  "bzip2":       {"bins": ["bzip2"]},
  "choose":      {"bins": ["choose"]},
  "dasel":       {"bins": ["dasel"]},
  "dust":        {"bins": ["dust"]},
  "eza":         {"bins": ["eza"]},
  "fd":          {"bins": ["fd"]},
  "fzf":         {"bins": ["fzf"]},
  "gnuplot":     {"bins": ["gnuplot"]},
  "gping":       {"bins": ["gping"]},
  "htop":        {"bins": ["htop"]},
  "hx":          {"bins": ["hx"]},
  "hyperfine":   {"bins": ["hyperfine"]},
  "jq":          {"bins": ["jq"],
                  "libs": ["libjq.so", "libjq.so.1", "libjq.so.1.0.4", "libonig.so.5"]},
  "just":        {"bins": ["just"]},
  "kak":         {"bins": ["kak"]},
  "micro":       {"bins": ["micro"]},
  "nvim":        {"bins": ["nvim"]},
  "patchelf":    {"bins": ["patchelf"]},
  "pigz":        {"bins": ["pigz"]},
  "pv":          {"bins": ["pv"]},
  "rg":          {"bins": ["rg"]},
  "rsync":       {"bins": ["rsync"],
                  "libs": ["libxxhash.so.0"]},
  "ruff":        {"bins": ["ruff"]},
  "sd":          {"bins": ["sd"]},
  "shfmt":       {"bins": ["shfmt"]},
  "starship":    {"bins": ["starship"]},
  "stylua":      {"bins": ["stylua"]},
  "tldr":        {"bins": ["tldr"]},
  "tmux":        {"bins": ["tmux"],
                  "libs": ["libevent_core-2.1.so.6"]},
  "tree-sitter": {"bins": ["tree-sitter"]},
  "ty":          {"bins": ["ty"]},
  "uv":          {"bins": ["uv"]},
  "vim":         {"bins": ["vim", "vim.bin"]},
  "xsel":        {"bins": ["xsel"]},
  "xterm":       {"bins": ["xterm", "resize"]},
  "yank":        {"bins": ["yank"]},
  "yq":          {"bins": ["yq"]},
  "zoxide":      {"bins": ["zoxide"]},

  "octave": {
    "bins":     ["octave"],
    "libs":     [
      "liboctave.so.13",
      "liboctinterp.so.15",
      "liboctmex.so.1",
      "libfftw3.so.3",
      "libfftw3_threads.so.3",
      "libfftw3f.so.3",
      "libfftw3f_threads.so.3",
      "libhdf5.so.103",
      "libsz.so.2",
      "libaec.so.0",
      "libarpack.so.2",
      "libopenblas.so.0",
      "libopenblasp.so.0",
      "libsatlas.so.3",
      "libtbb.so.2",
      "libcholmod.so.3",
      "libumfpack.so.5",
      "libamd.so.2",
      "libcamd.so.2",
      "libcolamd.so.2",
      "libccolamd.so.2",
      "libcxsparse.so.3",
      "libsuitesparseconfig.so.4",
      "libspqr.so.2",
      "libglpk.so.40",
      "libgmp.so.10",
      "libqhull_r.so.7",
      "libgfortran.so.5",
      "libgomp.so.1",
      "libquadmath.so.0",
      "libportaudio.so.2",
      "libsndfile.so.1",
      "libasound.so.2",
      "libFLAC.so.8",
      "libgsm.so.1",
      "libogg.so.0",
      "libvorbis.so.0",
      "libvorbisenc.so.2"
    ],
    "optional": true
  }
}
