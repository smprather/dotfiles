# Files and directories excluded from "git archive" and GitHub's auto-generated
# source archives (Source code .tar.gz / .zip on releases).
# These are dev/build/AI tooling — end users do not need them to run ./install
# or .\install.ps1.

# AI / agent instructions
/AGENTS.md                      export-ignore
/CLAUDE.md                      export-ignore
/INSTALL_PYTHON_PORT_PLAN.md    export-ignore
/.github                        export-ignore

# Git hooks (dev mode only; installed by ./install --dev or copied manually)
/hooks                          export-ignore

# Build and maintenance scripts
/strip_all_elf_binaries         export-ignore
/update_tmux_plugins            export-ignore
/update_tldr_cache              export-ignore
/release                        export-ignore
/pre_built/build_scripts        export-ignore
/pre_built/ADDING_BINARIES.md   export-ignore

# Tree-sitter build tooling (prebuilt/ and vendor/ are kept — installer needs them)
/treesitter/build_parsers       export-ignore

# Test harness
/tests                          export-ignore

# Stray root files not used by installers
/package.json                   export-ignore
/package-lock.json              export-ignore
