#!/bin/bash
# Pre-commit hook:
#   1. Remove .git directories from embedded repositories.
#   2. Strip repo ELF payloads when staged binary/archive candidates change.

set -euo pipefail

script_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")/../" && pwd)

# --- 1. Embedded git repository cleanup ---

echo "Pre-commit: Checking for embedded git repositories..."

embedded_gits=$(find . -mindepth 2 -type d -name ".git" 2>/dev/null)

if [[ -n "$embedded_gits" ]]; then
    echo "Found embedded git repositories, removing .git directories:"
    while IFS= read -r git_dir; do
        echo "  Removing: $git_dir"
        rm -rf "$git_dir"
    done <<< "$embedded_gits"
    echo "Re-staging affected files..."
    git add -A
    echo "✓ Cleaned up embedded git repositories"
else
    echo "✓ No embedded git repositories found"
fi

# --- 2. Strip repo binaries and binary archives ---

staged_strip_candidates=$(
    git diff --cached --name-only --diff-filter=ACM |
        grep -E '(^|/)([^/]+)$' |
        grep -E '\.(gz|so|tar|tgz|tbz2|txz|tar\.bz2|tar\.gz|tar\.xz)$|(^|/)(bin|lib64|grammars|parser)/' || true
)

if [[ -n "$staged_strip_candidates" ]]; then
    echo "Pre-commit: Stripping repo binaries and archives..."

    if ! command -v strip >/dev/null; then
        echo "  WARNING: 'strip' not found in PATH — skipping ELF stripping." >&2
        echo "  Run ./strip_all_elf_binaries manually before committing binary/archive changes." >&2
    else
        "$script_dir/strip_all_elf_binaries"
        # Re-stage candidate files, converted tar.bz2 names, removals, and updated manifests
        # without sweeping unrelated untracked files into the commit.
        git add -u
        while IFS= read -r candidate; do
            [[ -z "$candidate" ]] && continue
            [[ -e "$candidate" ]] && git add -- "$candidate"
            case "$candidate" in
            *.tar.gz) converted="${candidate%.tar.gz}.tar.bz2" ;;
            *.tgz) converted="${candidate%.tgz}.tar.bz2" ;;
            *.tar.xz) converted="${candidate%.tar.xz}.tar.bz2" ;;
            *.txz) converted="${candidate%.txz}.tar.bz2" ;;
            *.tbz2) converted="${candidate%.tbz2}.tar.bz2" ;;
            *.tar) converted="${candidate%.tar}.tar.bz2" ;;
            *) converted="" ;;
            esac
            [[ -n "$converted" && -e "$converted" ]] && git add -- "$converted"
        done <<< "$staged_strip_candidates"
        [[ -f .strip-manifest ]] && git add .strip-manifest
        [[ -f pre_built/.strip-manifest ]] && git add pre_built/.strip-manifest
        echo "✓ Repo binaries and archives stripped and staged"
    fi
fi

exit 0
