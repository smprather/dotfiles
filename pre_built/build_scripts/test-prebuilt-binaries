#!/usr/bin/env python3
"""
test-prebuilt-binaries: smoke-test installed binary and runtime payloads.

Runs ./install --dest-dir /tmp/... --no-backup --no-fonts --no-tldr-cache to get
a real deployment layout, then probes each executable in <dest>/.local/bin/ for:
  - exit 127  (loader failure / broken ELF)
  - exit 139  (SIGSEGV)
  - "symbol lookup error" / "undefined symbol" in output
It also checks runtime sentinels for shipped editor payloads and runs Neovim
headless against the installed runtime.

Any other outcome (including "bad option" exit 1/2, or timeout on an interactive
binary) counts as OK — the binary loaded and ran.

Exit 0: all clean.  Exit 1: failures detected (fails the pre-commit).

Usage:
    pre_built/build_scripts/test-prebuilt-binaries
    pre_built/build_scripts/test-prebuilt-binaries --keep   # don't delete tmpdir
"""

from __future__ import print_function

import argparse
import os
import shutil
import subprocess
import sys
import tempfile

FATAL_EXIT_CODES = {127, 139}

FATAL_OUTPUT_PATTERNS = (
    "symbol lookup error",
    "undefined symbol",
)

# Binaries that are non-ELF wrappers (shell scripts) — skip exec check.
NON_ELF_WRAPPERS = {"vim"}

# Binaries that require a display/terminal — ldd-check only, skip exec.
NO_EXEC = {"xterm"}

# Per-binary probe flags tried in order. First non-fatal result wins.
PROBE_FLAGS = {
    "tmux":    [["-V"]],
    "kak":     [["-version"]],
    "resize":  [["--help"]],
    "bzip2":   [["--help"]],
    "nvim":    [["--version"]],
}
DEFAULT_PROBE = [["--version"], ["-V"], ["-version"], ["--help"]]


def is_elf(path):
    try:
        with open(path, "rb") as fh:
            return fh.read(4) == b"\x7fELF"
    except IOError:
        return False


def ldd_check(path):
    ldd = "/usr/bin/ldd"
    if not os.path.isfile(ldd):
        return []
    try:
        proc = subprocess.run(
            [ldd, path],
            stdout=subprocess.PIPE, stderr=subprocess.PIPE, timeout=5,
        )
        return [
            line.strip()
            for line in proc.stdout.decode("utf-8", "replace").splitlines()
            if "not found" in line
        ]
    except (OSError, subprocess.TimeoutExpired):
        return []


def output_excerpt(data, limit=400):
    if isinstance(data, bytes):
        text = data.decode("utf-8", "replace")
    else:
        text = str(data)
    text = text.strip().replace("\n", "\\n")
    if len(text) > limit:
        return text[:limit] + "..."
    return text


def require_path(path, label, failures):
    if os.path.exists(path):
        print("  OK   (path):         {}".format(label))
        return True
    print("  FAIL (path):         {}  missing {}".format(label, path))
    failures.append((label, "missing {}".format(path)))
    return False


def probe_binary(binary_path):
    """Return (ok, detail)."""
    name = os.path.basename(binary_path)
    flag_list = PROBE_FLAGS.get(name, DEFAULT_PROBE)

    last_code = None
    last_out = ""

    for flags in flag_list:
        try:
            proc = subprocess.run(
                [binary_path] + flags,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                timeout=4,
            )
            combined = proc.stdout.decode("utf-8", "replace")
            last_code = proc.returncode
            last_out = combined

            # Negative returncode = killed by signal (e.g. -11 = SIGSEGV)
            if proc.returncode in FATAL_EXIT_CODES or proc.returncode < 0:
                continue  # try next flag set before declaring failure

            for pat in FATAL_OUTPUT_PATTERNS:
                if pat in combined:
                    return False, combined[:200].strip()

            first_line = combined.split("\n")[0][:100].strip()
            return True, first_line or "(exit {})".format(proc.returncode)

        except subprocess.TimeoutExpired:
            return True, "(interactive — timeout counts as OK)"
        except OSError as exc:
            return False, "OSError: {}".format(exc)

    for pat in FATAL_OUTPUT_PATTERNS:
        if pat in last_out:
            return False, last_out[:200].strip()
    code_str = "signal {}".format(-last_code) if last_code is not None and last_code < 0 else "exit {}".format(last_code)
    return False, "{} — {}".format(code_str, last_out[:200].strip())


def smoke_runtime_layout(tmpdir):
    failures = []
    bin_dir = os.path.join(tmpdir, ".local", "bin")

    def has_bin(name):
        return os.path.exists(os.path.join(bin_dir, name))

    print("Smoke-testing installed runtimes...\n")

    if has_bin("nvim"):
        nvim = os.path.join(bin_dir, "nvim")
        runtime = os.path.join(tmpdir, ".local", "share", "nvim", "runtime")
        if require_path(os.path.join(runtime, "filetype.lua"), "nvim runtime", failures):
            env = os.environ.copy()
            env.update({
                "HOME": tmpdir,
                "XDG_CACHE_HOME": os.path.join(tmpdir, ".cache", "nvim-smoke"),
                "XDG_STATE_HOME": os.path.join(tmpdir, ".local", "state", "nvim-smoke"),
            })
            lua_check = (
                "local expected = vim.env.HOME .. '/.local/share/nvim/runtime'; "
                "local rtp = vim.o.runtimepath; "
                "if not rtp:find(expected, 1, true) then "
                "vim.api.nvim_err_writeln(rtp); vim.cmd('cquit 1'); end; "
                "if vim.fn.filereadable(expected .. '/filetype.lua') ~= 1 then "
                "vim.api.nvim_err_writeln(expected); vim.cmd('cquit 1'); end"
            )
            try:
                proc = subprocess.run(
                    [nvim, "--clean", "--headless", "-n", "+lua " + lua_check, "+qa"],
                    cwd=tmpdir,
                    env=env,
                    stdout=subprocess.PIPE,
                    stderr=subprocess.STDOUT,
                    timeout=10,
                )
            except subprocess.TimeoutExpired:
                print("  FAIL (headless):     nvim runtime  timeout")
                failures.append(("nvim runtime", "headless timeout"))
            except Exception as exc:
                print("  FAIL (headless):     nvim runtime  {}".format(exc))
                failures.append(("nvim runtime", str(exc)))
            else:
                if proc.returncode == 0:
                    print("  OK   (headless):     nvim runtime")
                else:
                    detail = output_excerpt(proc.stdout)
                    print("  FAIL (headless):     nvim runtime  {}".format(detail))
                    failures.append(("nvim runtime", detail))

    if has_bin("vim") or has_bin("vim.bin"):
        require_path(
            os.path.join(tmpdir, ".local", "share", "vim", "vim92", "filetype.vim"),
            "vim runtime",
            failures,
        )

    if has_bin("hx"):
        require_path(
            os.path.join(tmpdir, ".config", "helix", "runtime", "tutor"),
            "helix runtime",
            failures,
        )

    parsers = os.path.join(tmpdir, ".local", "share", "nvim", "tree-sitter-parsers")
    if os.path.isdir(parsers):
        require_path(os.path.join(parsers, "parser", "python.so"), "tree-sitter python parser", failures)
        require_path(os.path.join(parsers, "queries", "python", "highlights.scm"), "tree-sitter python query", failures)
        require_path(os.path.join(parsers, "parser-info", "python.lua"), "tree-sitter python parser-info", failures)


    if not failures:
        print("Runtime payloads OK")
    print()
    return failures


def main():
    p = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p.add_argument("--keep", action="store_true",
                   help="keep the temp install dir after testing")
    args = p.parse_args()

    script_dir = os.path.dirname(os.path.abspath(__file__))
    repo_dir = os.path.dirname(os.path.dirname(script_dir))
    installer = os.path.join(repo_dir, "install")

    tmpdir = tempfile.mkdtemp(prefix="dotfiles-smoketest-")
    try:
        print("Installing to {} ...".format(tmpdir))
        proc = subprocess.run(
            [installer,
             "--dest-dir", tmpdir,
             "--no-backup",
             "--no-fonts",
             "--no-tldr-cache"],
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            timeout=300,
        )
        install_out = proc.stdout.decode("utf-8", "replace")
        if proc.returncode != 0:
            print("Install failed (exit {}):\n{}".format(proc.returncode, install_out))
            return 1

        bin_dir = os.path.join(tmpdir, ".local", "bin")
        if not os.path.isdir(bin_dir):
            print("ERROR: {} not created by installer".format(bin_dir))
            return 1

        print("Smoke-testing binaries in {} ...\n".format(bin_dir))
        failures = []
        tested = 0
        skipped = 0

        for fname in sorted(os.listdir(bin_dir)):
            fpath = os.path.join(bin_dir, fname)
            if not os.path.isfile(fpath) or not os.access(fpath, os.X_OK):
                continue

            if fname in NON_ELF_WRAPPERS or not is_elf(fpath):
                print("  skip (non-ELF):      {}".format(fname))
                skipped += 1
                continue

            missing = ldd_check(fpath)
            if missing:
                msg = "missing .so: " + "; ".join(missing)
                print("  FAIL (ldd):          {:20s}  {}".format(fname, missing[0]))
                failures.append((fname, msg))
                continue

            if fname in NO_EXEC:
                print("  OK   (ldd-only):     {}".format(fname))
                tested += 1
                continue

            tested += 1
            ok, detail = probe_binary(fpath)
            status = "OK:  " if ok else "FAIL:"
            print("  {}                 {:20s}  {}".format(status, fname, detail))
            if not ok:
                failures.append((fname, detail))

        print()
        runtime_failures = smoke_runtime_layout(tmpdir)
        failures.extend(runtime_failures)

        if failures:
            print("FAILED: {} smoke checks:".format(len(failures)))
            for name, msg in failures:
                print("  {}: {}".format(name, msg))
            return 1

        print("All {} binaries OK ({} non-ELF skipped); runtimes OK".format(tested, skipped))
        return 0

    except subprocess.TimeoutExpired:
        print("ERROR: installer timed out")
        return 1
    finally:
        if not args.keep:
            shutil.rmtree(tmpdir, ignore_errors=True)
        else:
            print("Kept: {}".format(tmpdir))


if __name__ == "__main__":
    sys.exit(main())
