# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def parse_args():
    p = argparse.ArgumentParser(
        description="Query installed pre-built binary versions.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    p.add_argument("--bin-dir", default=os.path.expanduser("~/.local/bin"),
                   help="directory containing installed binaries (default: ~/.local/bin)")
    p.add_argument("--format", choices=["json", "tsv", "text"], default="json",
                   help="output format (default: json)")
    p.add_argument("--missing-only", action="store_true",
                   help="only show tools that could not be versioned")
    return p.parse_args()


def collect(bin_dir):
    results = []
    for binary_name, display_name, homepage, get_version in TOOLS:
        binary_path = os.path.join(bin_dir, binary_name)
        if not os.path.isfile(binary_path):
            version = None
            status = "missing"
        elif not os.access(binary_path, os.X_OK):
            version = None
            status = "not-executable"
        else:
            version = get_version(binary_path)
            status = "ok" if version else "unknown"
        results.append({
            "name":     display_name,
            "binary":   binary_name,
            "version":  version,
            "status":   status,
            "homepage": homepage,
            "path":     binary_path,
        })
    return results


def fmt_json(results):
    print(json.dumps(results, indent=2))


def fmt_tsv(results):
    print("binary\tname\tversion\tstatus\thomepage")
    for r in results:
        print("{}\t{}\t{}\t{}\t{}".format(
            r["binary"], r["name"], r["version"] or "", r["status"], r["homepage"]))


def fmt_text(results):
    col_b = max(len(r["binary"])  for r in results)
    col_v = max(len(r["version"] or "—") for r in results)
    col_s = max(len(r["status"])  for r in results)
    fmt = "  {:<{b}}  {:<{v}}  {:<{s}}  {}"
    header = fmt.format("BINARY", "VERSION", "STATUS", "HOMEPAGE",
                        b=col_b, v=col_v, s=col_s)
    print(header)
    print("  " + "-" * (len(header) - 2))
    for r in results:
        print(fmt.format(
            r["binary"],
            r["version"] or "—",
            r["status"],
            r["homepage"],
            b=col_b, v=col_v, s=col_s,
        ))
    ok      = sum(1 for r in results if r["status"] == "ok")
    unknown = sum(1 for r in results if r["status"] == "unknown")
    missing = sum(1 for r in results if r["status"] == "missing")
    print()
    print("  {} versioned, {} unknown, {} missing".format(ok, unknown, missing))


def main():
    args = parse_args()
    results = collect(args.bin_dir)

    if args.missing_only:
        results = [r for r in results if r["status"] != "ok"]

    if not results:
        print("All tools versioned successfully.", file=sys.stderr)
        return 0

    {"json": fmt_json, "tsv": fmt_tsv, "text": fmt_text}[args.format](results)
    return 0


if __name__ == "__main__":
    sys.exit(main())
