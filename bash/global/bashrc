set_prompt() {
    local include_host=${DOTFILES_CFG_PROMPT_INCLUDE_HOST}
    local prompt_color=${DOTFILES_CFG_PROMPT_COLOR_NORMAL}
    local prompt_joined=""
    local prompt_parts=()

    if [[ -n $LSB_JOBID ]]; then
        prompt_parts+=('LSF')
        prompt_color="${DOTFILES_CFG_PROMPT_COLOR_FARM}"
    fi

    prompt_joined=$(join_by : "${prompt_parts[@]}")

    [[ $include_host == "1" ]] && prompt_joined+=":$(hostname)"

    get_prompt_uid() {
        local whoiam=$(/bin/whoami)
        if [[ "$whoiam" != "$USER" ]]; then
            printf "$whoiam "
        else
            printf ""
        fi
    }

    # history -a: Always flush the latest command to the history file
    #PROMPT_COMMAND="printf '$BOLD$BLUE'"'; history -a; echo $(realpath .); '"printf '$NORMAL'"
    #PROMPT_COMMAND="printf '$BOLD$CYAN'"'; history -a; echo $(realpath .); '"printf '$NORMAL'"

    PS1="${PROMPT_YELLOW}\$(get_prompt_uid)${prompt_color}\$ ${PROMPT_WHITE}"
    export PROMPT_COMMAND="/bin/stty '$(stty -g)'"
}
unset PROMPT_COMMAND
/bin/stty sane
if is_truthy "${DOTFILES_CFG_ENABLE_STARSHIP}" && command -v starship >/dev/null; then
    export STARSHIP_CONFIG="$BASH_CONFIG_ROOT_DIR/../starship/starship.toml"
    eval "$(starship init bash)"
    # Sometimes, ctrl-c killing a process leaves the -echo stty option enabled, which
    # makes it so that you can't see the text you're typing (like when entering a pw).
    # Use every prompt print to disable that state and make typing visible.
    export PROMPT_COMMAND="/bin/stty '$(stty -g)';$PROMPT_COMMAND"
else
    set_prompt
fi

