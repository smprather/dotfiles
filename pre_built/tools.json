    "bins":     "List of bin/*.bz2 stems (without .bz2) owned by this tool.",
    "libs":     "List of lib64/*.bz2 stems exclusively owned by this tool. Omit or leave empty for libs shared by multiple tools — those are always installed. Exclusively-owned libs are skipped when the tool is not selected.",
    "optional": "If true, not installed by default. User must opt in with --add-tools."
  },

