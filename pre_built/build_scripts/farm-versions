#!/usr/bin/python3
"""
farm-versions: query installed pre-built binary versions.

Outputs a structured version table for all known pre-built tools.
Use this to update README tables or changelog entries.

Usage:
    ./farm-versions [--bin-dir DIR] [--format json|tsv|text] [--missing-only]

Formats:
    json  — {"name": "bat", "version": "0.26.1", "homepage": "..."}  (default)
    tsv   — name<TAB>version<TAB>homepage  (one row per tool)
    text  — aligned table suitable for copy-paste into a terminal
"""
from __future__ import print_function

import argparse
import json
import os
import re
import subprocess
import sys


# ---------------------------------------------------------------------------
# Version strategies
# ---------------------------------------------------------------------------

def _run(cmd, timeout=5):
    """Run a command, return combined stdout+stderr, empty string on failure."""
    try:
        proc = subprocess.run(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            timeout=timeout,
        )
        return proc.stdout.decode("utf-8", "replace")
    except (OSError, subprocess.TimeoutExpired):
        return ""


def _strings(path):
    """Return strings output for a binary (fallback for stripped Go/C++ binaries)."""
    try:
        proc = subprocess.run(
            ["/usr/bin/strings", path],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            timeout=10,
        )
        return proc.stdout.decode("utf-8", "replace")
    except (OSError, subprocess.TimeoutExpired):
        return ""


def _go_mod_version(binary):
    """Extract module version from Go build info embedded in the binary."""
    go = "/usr/local/go/bin/go"
    if not os.path.isfile(go):
        go = "/usr/bin/go"
    if not os.path.isfile(go):
        return None
    out = _run([go, "version", "-m", binary], timeout=10)
    for line in out.splitlines():
        line = line.strip()
        if line.startswith("mod\t"):
            parts = line.split("\t")
            if len(parts) >= 3:
                ver = parts[2].lstrip("v").split("+")[0]
                return ver
    return None


def strategy_flag(flags, pattern=r"([0-9]+\.[0-9]+[\w.\-]*)"):
    """Run binary with flags, extract first regex match."""
    def _get(binary):
        out = _run([binary] + flags)
        m = re.search(pattern, out)
        return m.group(1).strip() if m else None
    return _get


def strategy_strings(pattern):
    """Search strings output of the binary for a regex pattern."""
    def _get(binary):
        out = _strings(binary)
        m = re.search(pattern, out)
        return m.group(1).strip() if m else None
    return _get


def strategy_go_mod():
    """Extract version from embedded Go module metadata."""
    def _get(binary):
        return _go_mod_version(binary)
    return _get


def strategy_first(*strategies):
    """Try strategies in order, return first non-None result."""
    def _get(binary):
        for s in strategies:
            result = s(binary)
            if result:
                return result
        return None
    return _get


